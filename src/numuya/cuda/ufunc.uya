    var arg_right_ptr: usize = right_ptr;
    var arg_n: usize = n;
    var arg_left_stride: usize = UFUNC_F32_ELEMENT_SIZE;
    var arg_right_stride: usize = UFUNC_F32_ELEMENT_SIZE;

    var args: [usize: 6] = [
        (&arg_result_ptr) as usize,
