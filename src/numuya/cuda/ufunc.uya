}

export fn gpu_sub_f64(state: &BackendState, left: &DeviceArray<f64>, right: &DeviceArray<f64>) !DeviceArray<f64> {
    const result_shape: Shape = try broadcast_shapes(left.shape, right.shape);
    var left_view: DeviceArray<f64> = try device_broadcast_to<f64>(left, clone_shape(&result_shape));
    var right_view: DeviceArray<f64> = try device_broadcast_to<f64>(right, clone_shape(&result_shape));
    const result: DeviceArray<f64> = try device_array_new<f64>(left.storage.pool, clone_shape(&result_shape), state.context, state.stream);

    const n: usize = try shape_size(result_shape);
    if n == 0 {
        device_storage_retain<f64>(result.storage);
        return DeviceArray<f64>{
            storage: result.storage,
            offset: result.offset,
            shape: result.shape,
            strides: result.strides,
            flags: result.flags,
            context: result.context,
            stream: result.stream,
        };
    }

    try launch_binary_f64_strided(state, SUB_F64_KERNEL, &left_view, &right_view, &result);

    device_storage_retain<f64>(result.storage);
    return DeviceArray<f64>{
        storage: result.storage,
        offset: result.offset,
        shape: result.shape,
        strides: result.strides,
        flags: result.flags,
        context: result.context,
        stream: result.stream,
    };
}

export fn gpu_neg_f64(state: &BackendState, input: &DeviceArray<f64>) !DeviceArray<f64> {
    const result: DeviceArray<f64> = try device_array_new<f64>(input.storage.pool, input.shape, state.context, state.stream);

    const n: usize = try shape_size(input.shape);
    if n == 0 {
        device_storage_retain<f64>(result.storage);
        return DeviceArray<f64>{
            storage: result.storage,
            offset: result.offset,
            shape: result.shape,
            strides: result.strides,
            flags: result.flags,
            context: result.context,
            stream: result.stream,
        };
    }

    try launch_unary_f64_strided(state, NEG_F64_KERNEL, input, &result);

    device_storage_retain<f64>(result.storage);
    return DeviceArray<f64>{
        storage: result.storage,
        offset: result.offset,
        shape: result.shape,
        strides: result.strides,
        flags: result.flags,
        context: result.context,
        stream: result.stream,
    };
}

