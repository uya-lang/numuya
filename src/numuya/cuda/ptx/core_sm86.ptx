    ld.param.u64    r64_res, [numuya_matmul_f32_param_0];
    ld.param.u64    r64_left, [numuya_matmul_f32_param_1];
    ld.param.u64    r64_right, [numuya_matmul_f32_param_2];
    ld.param.u64    r64_m, [numuya_matmul_f32_param_3];
    ld.param.u64    r64_k, [numuya_matmul_f32_param_4];
    ld.param.u64    r64_n, [numuya_matmul_f32_param_5];

    mov.u32         r32_tx, %tid.x;
    mov.u32         r32_ty, %tid.y;
    mov.u32         r32_bx, %ctaid.x;
    mov.u32         r32_by, %ctaid.y;

    cvt.u64.u32     r64_tx, r32_tx;
    cvt.u64.u32     r64_ty, r32_ty;
    cvt.u64.u32     r64_bx, r32_bx;
    cvt.u64.u32     r64_by, r32_by;

    mad.lo.u64      r64_row, r64_by, 16, r64_ty;
    mad.lo.u64      r64_col, r64_bx, 16, r64_tx;

    mov.f32         f32_sum, 0F00000000;
    mov.u64         r64_tile, 0;

TILE_LOOP:
    setp.ge.u64     p, r64_tile, r64_k;
    @p bra          TILE_DONE;

    mov.f32         f32_a, 0F00000000;
    add.u64         r64_a_col, r64_tile, r64_tx;
    setp.ge.u64     p, r64_row, r64_m;
    @p bra          LOAD_A_DONE;
    setp.ge.u64     p, r64_a_col, r64_k;
    @p bra          LOAD_A_DONE;
    mad.lo.u64      r64_tmp, r64_row, r64_k, r64_a_col;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_left, r64_tmp;
    ld.f32          f32_a, [r64_addr];

LOAD_A_DONE:
    mov.u64         r64_sbase_a, s_a;
    mad.lo.u64      r64_sidx, r64_ty, 16, r64_tx;
    mul.lo.u64      r64_saddr, r64_sidx, 4;
    add.u64         r64_saddr, r64_sbase_a, r64_saddr;
    st.shared.f32   [r64_saddr], f32_a;

    mov.f32         f32_b, 0F00000000;
    add.u64         r64_b_row, r64_tile, r64_ty;
    setp.ge.u64     p, r64_b_row, r64_k;
    @p bra          LOAD_B_DONE;
    setp.ge.u64     p, r64_col, r64_n;
    @p bra          LOAD_B_DONE;
    mad.lo.u64      r64_tmp, r64_b_row, r64_n, r64_col;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_right, r64_tmp;
    ld.f32          f32_b, [r64_addr];

LOAD_B_DONE:
    mov.u64         r64_sbase_b, s_b;
    mad.lo.u64      r64_sidx, r64_ty, 16, r64_tx;
    mul.lo.u64      r64_saddr, r64_sidx, 4;
    add.u64         r64_saddr, r64_sbase_b, r64_saddr;
    st.shared.f32   [r64_saddr], f32_b;

    bar.sync        0;

    mov.u32         r32_kk, 0;

MUL_LOOP:
    setp.ge.u32     p, r32_kk, 16;
    @p bra          MUL_DONE;
    cvt.u64.u32     r64_kk, r32_kk;

    mad.lo.u64      r64_sidx, r64_ty, 16, r64_kk;
    mul.lo.u64      r64_saddr, r64_sidx, 4;
    add.u64         r64_saddr, r64_sbase_a, r64_saddr;
    ld.shared.f32   f32_a, [r64_saddr];

    mad.lo.u64      r64_sidx, r64_kk, 16, r64_tx;
    mul.lo.u64      r64_saddr, r64_sidx, 4;
    add.u64         r64_saddr, r64_sbase_b, r64_saddr;
    ld.shared.f32   f32_b, [r64_saddr];

    fma.rn.f32      f32_sum, f32_a, f32_b, f32_sum;

    add.u32         r32_kk, r32_kk, 1;
    bra             MUL_LOOP;

MUL_DONE:
    bar.sync        0;
    add.u64         r64_tile, r64_tile, 16;
    bra             TILE_LOOP;

TILE_DONE:
    setp.ge.u64     p, r64_row, r64_m;
    @p bra          END;
    setp.ge.u64     p, r64_col, r64_n;
    @p bra          END;

    mad.lo.u64      r64_tmp, r64_row, r64_n, r64_col;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_res, r64_tmp;
    st.f32          [r64_addr], f32_sum;

END:
