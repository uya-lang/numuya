    .param .u64 numuya_matmul_f32_param_5
)
{
    .shared .f32 s_a[256];
    .shared .f32 s_b[256];

    .reg .u32   r32_tx, r32_ty, r32_bx, r32_by, r32_kk;
    .reg .u64   r64_res, r64_left, r64_right, r64_m, r64_k, r64_n;
    .reg .u64   r64_tx, r64_ty, r64_bx, r64_by, r64_row, r64_col, r64_tile, r64_kk;
