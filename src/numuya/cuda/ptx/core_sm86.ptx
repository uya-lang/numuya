.version 7.8
.target sm_86
.address_size 64

// NumUya core CUDA kernels for sm_86.
// This file is the source-of-truth for device code.  It is embedded into
// src/numuya/cuda/kernels_ptx.uya by src/numuya/_tools/embed_ptx.uya.
// No .cu source or nvcc invocation is required for the TDD path.

.visible .entry numuya_add_f64(
    .param .u64 numuya_add_f64_param_0,
    .param .u64 numuya_add_f64_param_1,
    .param .u64 numuya_add_f64_param_2,
    .param .u64 numuya_add_f64_param_3,
    .param .u64 numuya_add_f64_param_4,
    .param .u64 numuya_add_f64_param_5
)
{
    .reg .u32   r32_0, r32_1, r32_2, r32_3;
    .reg .u64   r64_0, r64_1, r64_2, r64_3, r64_4, r64_5, r64_6, r64_7, r64_8;
    .reg .f64   f64_0, f64_1, f64_2;
    .reg .pred  p;

    ld.param.u64    r64_0, [numuya_add_f64_param_0];
    ld.param.u64    r64_1, [numuya_add_f64_param_1];
    ld.param.u64    r64_2, [numuya_add_f64_param_2];
    ld.param.u64    r64_3, [numuya_add_f64_param_3];
    ld.param.u64    r64_4, [numuya_add_f64_param_4];
    ld.param.u64    r64_5, [numuya_add_f64_param_5];

    mov.u32         r32_0, %tid.x;
    cvt.u64.u32     r64_6, r32_0;
    mov.u32         r32_1, %ctaid.x;
    cvt.u64.u32     r64_7, r32_1;
    mov.u32         r32_2, %ntid.x;
    cvt.u64.u32     r64_8, r32_2;
    mad.lo.u64      r64_6, r64_7, r64_8, r64_6;

    setp.ge.u64     p, r64_6, r64_3;
    @p bra          END;

    mul.lo.u64      r64_7, r64_6, r64_4;
    add.u64         r64_7, r64_1, r64_7;
    ld.f64          f64_0, [r64_7];

    mul.lo.u64      r64_7, r64_6, r64_5;
    add.u64         r64_7, r64_2, r64_7;
    ld.f64          f64_1, [r64_7];

    add.f64         f64_2, f64_0, f64_1;

    mul.lo.u64      r64_7, r64_6, 8;
    add.u64         r64_7, r64_0, r64_7;
    st.f64          [r64_7], f64_2;

END:
    ret;
}

.visible .entry numuya_matmul_f32_aligned(
    .param .u64 numuya_matmul_f32_aligned_param_0,
    .param .u64 numuya_matmul_f32_aligned_param_1,
    .param .u64 numuya_matmul_f32_aligned_param_2,
    .param .u64 numuya_matmul_f32_aligned_param_3,
    .param .u64 numuya_matmul_f32_aligned_param_4,
    .param .u64 numuya_matmul_f32_aligned_param_5
)
{
    .shared .f32 s_a[256];
    .shared .f32 s_b[1024];

    .reg .u32   r32_tx, r32_ty, r32_bx, r32_by, r32_kk;
    .reg .u64   r64_res, r64_left, r64_right, r64_m, r64_k, r64_n;
    .reg .u64   r64_tx, r64_ty, r64_bx, r64_by, r64_row, r64_col0, r64_col1, r64_col2, r64_col3, r64_tile, r64_kk;
    .reg .u64   r64_a_col, r64_b_row, r64_tmp, r64_addr, r64_sbase_a, r64_sbase_b, r64_sidx, r64_saddr;
    .reg .f32   f32_sum0, f32_sum1, f32_sum2, f32_sum3, f32_a, f32_b0, f32_b1, f32_b2, f32_b3;
    .reg .pred  p;

    ld.param.u64    r64_res, [numuya_matmul_f32_aligned_param_0];
    ld.param.u64    r64_left, [numuya_matmul_f32_aligned_param_1];
    ld.param.u64    r64_right, [numuya_matmul_f32_aligned_param_2];
    ld.param.u64    r64_m, [numuya_matmul_f32_aligned_param_3];
    ld.param.u64    r64_k, [numuya_matmul_f32_aligned_param_4];
    ld.param.u64    r64_n, [numuya_matmul_f32_aligned_param_5];

    mov.u32         r32_tx, %tid.x;
    mov.u32         r32_ty, %tid.y;
    mov.u32         r32_bx, %ctaid.x;
    mov.u32         r32_by, %ctaid.y;

    cvt.u64.u32     r64_tx, r32_tx;
    cvt.u64.u32     r64_ty, r32_ty;
    cvt.u64.u32     r64_bx, r32_bx;
    cvt.u64.u32     r64_by, r32_by;

    mad.lo.u64      r64_row, r64_by, 16, r64_ty;
    mad.lo.u64      r64_col0, r64_bx, 64, r64_tx;
    add.u64         r64_col1, r64_col0, 16;
    add.u64         r64_col2, r64_col0, 32;
    add.u64         r64_col3, r64_col0, 48;

    mov.u64         r64_sbase_a, s_a;
    mov.u64         r64_sbase_b, s_b;
    mov.f32         f32_sum0, 0F00000000;
    mov.f32         f32_sum1, 0F00000000;
    mov.f32         f32_sum2, 0F00000000;
    mov.f32         f32_sum3, 0F00000000;
    mov.u64         r64_tile, 0;

ALIGNED_TILE_LOOP:
    setp.ge.u64     p, r64_tile, r64_k;
    @p bra          ALIGNED_TILE_DONE;

    add.u64         r64_a_col, r64_tile, r64_tx;
    mad.lo.u64      r64_tmp, r64_row, r64_k, r64_a_col;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_left, r64_tmp;
    ld.f32          f32_a, [r64_addr];

    mad.lo.u64      r64_sidx, r64_ty, 16, r64_tx;
    mul.lo.u64      r64_saddr, r64_sidx, 4;
    add.u64         r64_saddr, r64_sbase_a, r64_saddr;
    st.shared.f32   [r64_saddr], f32_a;

    add.u64         r64_b_row, r64_tile, r64_ty;
    mad.lo.u64      r64_tmp, r64_b_row, r64_n, r64_col0;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_right, r64_tmp;
    ld.f32          f32_b0, [r64_addr];

    mad.lo.u64      r64_sidx, r64_ty, 64, r64_tx;
    mul.lo.u64      r64_saddr, r64_sidx, 4;
    add.u64         r64_saddr, r64_sbase_b, r64_saddr;
    st.shared.f32   [r64_saddr], f32_b0;

    mad.lo.u64      r64_tmp, r64_b_row, r64_n, r64_col1;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_right, r64_tmp;
    ld.f32          f32_b1, [r64_addr];

    add.u64         r64_saddr, r64_saddr, 64;
    st.shared.f32   [r64_saddr], f32_b1;

    mad.lo.u64      r64_tmp, r64_b_row, r64_n, r64_col2;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_right, r64_tmp;
    ld.f32          f32_b2, [r64_addr];

    add.u64         r64_saddr, r64_saddr, 64;
    st.shared.f32   [r64_saddr], f32_b2;

    mad.lo.u64      r64_tmp, r64_b_row, r64_n, r64_col3;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_right, r64_tmp;
    ld.f32          f32_b3, [r64_addr];

    add.u64         r64_saddr, r64_saddr, 64;
    st.shared.f32   [r64_saddr], f32_b3;

    bar.sync        0;

    mul.lo.u64      r64_saddr, r64_ty, 64;
    add.u64         r64_saddr, r64_sbase_a, r64_saddr;
    mul.lo.u64      r64_addr, r64_tx, 4;
    add.u64         r64_addr, r64_sbase_b, r64_addr;
    mov.u32         r32_kk, 0;

ALIGNED_MUL_LOOP:
    setp.ge.u32     p, r32_kk, 16;
    @p bra          ALIGNED_MUL_DONE;
    cvt.u64.u32     r64_kk, r32_kk;

    mul.lo.u64      r64_tmp, r64_kk, 4;
    add.u64         r64_tmp, r64_saddr, r64_tmp;
    ld.shared.f32   f32_a, [r64_tmp];

    mul.lo.u64      r64_tmp, r64_kk, 256;
    add.u64         r64_tmp, r64_addr, r64_tmp;
    ld.shared.f32   f32_b0, [r64_tmp];
    ld.shared.f32   f32_b1, [r64_tmp+64];
    ld.shared.f32   f32_b2, [r64_tmp+128];
    ld.shared.f32   f32_b3, [r64_tmp+192];
    fma.rn.f32      f32_sum0, f32_a, f32_b0, f32_sum0;
    fma.rn.f32      f32_sum1, f32_a, f32_b1, f32_sum1;
    fma.rn.f32      f32_sum2, f32_a, f32_b2, f32_sum2;
    fma.rn.f32      f32_sum3, f32_a, f32_b3, f32_sum3;

    add.u32         r32_kk, r32_kk, 1;
    bra             ALIGNED_MUL_LOOP;

ALIGNED_MUL_DONE:

    bar.sync        0;
    add.u64         r64_tile, r64_tile, 16;
    bra             ALIGNED_TILE_LOOP;

ALIGNED_TILE_DONE:
    mad.lo.u64      r64_tmp, r64_row, r64_n, r64_col0;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_res, r64_tmp;
    st.f32          [r64_addr], f32_sum0;

    mad.lo.u64      r64_tmp, r64_row, r64_n, r64_col1;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_res, r64_tmp;
    st.f32          [r64_addr], f32_sum1;

    mad.lo.u64      r64_tmp, r64_row, r64_n, r64_col2;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_res, r64_tmp;
    st.f32          [r64_addr], f32_sum2;

    mad.lo.u64      r64_tmp, r64_row, r64_n, r64_col3;
    mul.lo.u64      r64_tmp, r64_tmp, 4;
    add.u64         r64_addr, r64_res, r64_tmp;
    st.f32          [r64_addr], f32_sum3;

ALIGNED_END:
    ret;
}

.visible .entry numuya_add_f32(
    .param .u64 numuya_add_f32_param_0,
    .param .u64 numuya_add_f32_param_1,
    .param .u64 numuya_add_f32_param_2,
    .param .u64 numuya_add_f32_param_3,
    .param .u64 numuya_add_f32_param_4,
    .param .u64 numuya_add_f32_param_5
)
{
    .reg .u32   r32_0, r32_1, r32_2, r32_3;
    .reg .u64   r64_0, r64_1, r64_2, r64_3, r64_4, r64_5, r64_6, r64_7, r64_8;
    .reg .f32   f32_0, f32_1, f32_2;
    .reg .pred  p;

    ld.param.u64    r64_0, [numuya_add_f32_param_0];
    ld.param.u64    r64_1, [numuya_add_f32_param_1];
    ld.param.u64    r64_2, [numuya_add_f32_param_2];
    ld.param.u64    r64_3, [numuya_add_f32_param_3];
    ld.param.u64    r64_4, [numuya_add_f32_param_4];
    ld.param.u64    r64_5, [numuya_add_f32_param_5];

    mov.u32         r32_0, %tid.x;
    cvt.u64.u32     r64_6, r32_0;
    mov.u32         r32_1, %ctaid.x;
    cvt.u64.u32     r64_7, r32_1;
    mov.u32         r32_2, %ntid.x;
    cvt.u64.u32     r64_8, r32_2;
    mad.lo.u64      r64_6, r64_7, r64_8, r64_6;

    setp.ge.u64     p, r64_6, r64_3;
    @p bra          END;

    mul.lo.u64      r64_7, r64_6, r64_4;
    add.u64         r64_7, r64_1, r64_7;
    ld.f32          f32_0, [r64_7];

    mul.lo.u64      r64_7, r64_6, r64_5;
    add.u64         r64_7, r64_2, r64_7;
    ld.f32          f32_1, [r64_7];

    add.f32         f32_2, f32_0, f32_1;

    mul.lo.u64      r64_7, r64_6, 4;
    add.u64         r64_7, r64_0, r64_7;
    st.f32          [r64_7], f32_2;

END:
    ret;
}

.visible .entry numuya_mul_f64(
    .param .u64 numuya_mul_f64_param_0,
    .param .u64 numuya_mul_f64_param_1,
    .param .u64 numuya_mul_f64_param_2,
    .param .u64 numuya_mul_f64_param_3,
    .param .u64 numuya_mul_f64_param_4,
    .param .u64 numuya_mul_f64_param_5
)
{
    .reg .u32   r32_0, r32_1, r32_2, r32_3;
    .reg .u64   r64_0, r64_1, r64_2, r64_3, r64_4, r64_5, r64_6, r64_7, r64_8;
    .reg .f64   f64_0, f64_1, f64_2;
    .reg .pred  p;

    ld.param.u64    r64_0, [numuya_mul_f64_param_0];
    ld.param.u64    r64_1, [numuya_mul_f64_param_1];
    ld.param.u64    r64_2, [numuya_mul_f64_param_2];
    ld.param.u64    r64_3, [numuya_mul_f64_param_3];
    ld.param.u64    r64_4, [numuya_mul_f64_param_4];
    ld.param.u64    r64_5, [numuya_mul_f64_param_5];

    mov.u32         r32_0, %tid.x;
    cvt.u64.u32     r64_6, r32_0;
    mov.u32         r32_1, %ctaid.x;
    cvt.u64.u32     r64_7, r32_1;
    mov.u32         r32_2, %ntid.x;
    cvt.u64.u32     r64_8, r32_2;
    mad.lo.u64      r64_6, r64_7, r64_8, r64_6;

    setp.ge.u64     p, r64_6, r64_3;
    @p bra          END;

    mul.lo.u64      r64_7, r64_6, r64_4;
    add.u64         r64_7, r64_1, r64_7;
    ld.f64          f64_0, [r64_7];

    mul.lo.u64      r64_7, r64_6, r64_5;
    add.u64         r64_7, r64_2, r64_7;
    ld.f64          f64_1, [r64_7];

    mul.f64         f64_2, f64_0, f64_1;

    mul.lo.u64      r64_7, r64_6, 8;
    add.u64         r64_7, r64_0, r64_7;
    st.f64          [r64_7], f64_2;

END:
    ret;
}

.visible .entry numuya_add_f64_strided(
    .param .u64 numuya_add_f64_strided_param_0,
    .param .u64 numuya_add_f64_strided_param_1,
    .param .u64 numuya_add_f64_strided_param_2,
    .param .u64 numuya_add_f64_strided_param_3,
    .param .u64 numuya_add_f64_strided_param_4
)
{
    .reg .u32   r32_t, r32_b, r32_nt;
    .reg .u64   r64_res, r64_left, r64_right, r64_n, r64_params;
    .reg .u64   r64_linear, r64_remaining, r64_axis, r64_rank;
    .reg .u64   r64_coord, r64_dim, r64_tmp, r64_addr;
    .reg .u64   r64_left_off, r64_right_off, r64_res_off;
    .reg .f64   f64_l, f64_r, f64_o;
    .reg .pred  p;

    ld.param.u64    r64_res, [numuya_add_f64_strided_param_0];
    ld.param.u64    r64_left, [numuya_add_f64_strided_param_1];
    ld.param.u64    r64_right, [numuya_add_f64_strided_param_2];
    ld.param.u64    r64_n, [numuya_add_f64_strided_param_3];
    ld.param.u64    r64_params, [numuya_add_f64_strided_param_4];

    mov.u32         r32_t, %tid.x;
    cvt.u64.u32     r64_linear, r32_t;
    mov.u32         r32_b, %ctaid.x;
    cvt.u64.u32     r64_tmp, r32_b;
    mov.u32         r32_nt, %ntid.x;
    cvt.u64.u32     r64_addr, r32_nt;
    mad.lo.u64      r64_linear, r64_tmp, r64_addr, r64_linear;

    setp.ge.u64     p, r64_linear, r64_n;
    @p bra          END;

    ld.u64          r64_rank, [r64_params];
    mov.u64         r64_axis, 0;
    mov.u64         r64_left_off, 0;
    mov.u64         r64_right_off, 0;
    mov.u64         r64_res_off, 0;
    mov.u64         r64_remaining, r64_linear;

AXIS_LOOP:
    setp.ge.u64     p, r64_axis, r64_rank;
    @p bra          AXIS_DONE;

    add.u64         r64_tmp, r64_axis, 1;
    shl.b64         r64_tmp, r64_tmp, 3;
    add.u64         r64_addr, r64_params, r64_tmp;
    ld.u64          r64_dim, [r64_addr];

    div.u64         r64_tmp, r64_remaining, r64_dim;
    rem.u64         r64_coord, r64_remaining, r64_dim;
    mov.u64         r64_remaining, r64_tmp;

    add.u64         r64_tmp, r64_axis, 17;
    shl.b64         r64_tmp, r64_tmp, 3;
    add.u64         r64_addr, r64_params, r64_tmp;
    ld.u64          r64_tmp, [r64_addr];
    mad.lo.u64      r64_left_off, r64_coord, r64_tmp, r64_left_off;

    add.u64         r64_tmp, r64_axis, 33;
    shl.b64         r64_tmp, r64_tmp, 3;
    add.u64         r64_addr, r64_params, r64_tmp;
    ld.u64          r64_tmp, [r64_addr];
    mad.lo.u64      r64_right_off, r64_coord, r64_tmp, r64_right_off;

    add.u64         r64_tmp, r64_axis, 49;
    shl.b64         r64_tmp, r64_tmp, 3;
    add.u64         r64_addr, r64_params, r64_tmp;
    ld.u64          r64_tmp, [r64_addr];
    mad.lo.u64      r64_res_off, r64_coord, r64_tmp, r64_res_off;

    add.u64         r64_axis, r64_axis, 1;
    bra             AXIS_LOOP;

AXIS_DONE:
    add.u64         r64_addr, r64_left, r64_left_off;
    ld.f64          f64_l, [r64_addr];
    add.u64         r64_addr, r64_right, r64_right_off;
    ld.f64          f64_r, [r64_addr];
    add.f64         f64_o, f64_l, f64_r;
    add.u64         r64_addr, r64_res, r64_res_off;
    st.f64          [r64_addr], f64_o;

END:
    ret;
}

.visible .entry numuya_sum_all_f64(
    .param .u64 numuya_sum_all_f64_param_0,
    .param .u64 numuya_sum_all_f64_param_1,
    .param .u64 numuya_sum_all_f64_param_2,
    .param .u64 numuya_sum_all_f64_param_3
)
{
    .shared .f64 sdata[256];

    .reg .u32   r32_tid, r32_bid, r32_ntid, r32_nctaid, r32_s, r32_tmp;
    .reg .u64   r64_result, r64_input, r64_n, r64_tid, r64_bid, r64_ntid, r64_nctaid, r64_stride, r64_idx;
    .reg .u64   r64_off, r64_addr_in, r64_sbase, r64_saddr, r64_addr;
    .reg .f64   f64_sum, f64_val;
    .reg .pred  p;

    ld.param.u64    r64_result, [numuya_sum_all_f64_param_0];
    ld.param.u64    r64_input,  [numuya_sum_all_f64_param_1];
    ld.param.u64    r64_n,      [numuya_sum_all_f64_param_2];

    mov.u32         r32_tid, %tid.x;
    mov.u32         r32_bid, %ctaid.x;
    mov.u32         r32_ntid, %ntid.x;
    mov.u32         r32_nctaid, %nctaid.x;

    cvt.u64.u32     r64_tid, r32_tid;
    cvt.u64.u32     r64_bid, r32_bid;
    cvt.u64.u32     r64_ntid, r32_ntid;
    cvt.u64.u32     r64_nctaid, r32_nctaid;
    mul.lo.u64      r64_stride, r64_ntid, r64_nctaid;

    mov.f64         f64_sum, 0D0000000000000000;
    mad.lo.u64      r64_idx, r64_bid, r64_ntid, r64_tid;

LOOP:
    setp.ge.u64     p, r64_idx, r64_n;
    @p bra          LOOP_DONE;
    mul.lo.u64      r64_off, r64_idx, 8;
    add.u64         r64_addr_in, r64_input, r64_off;
    ld.f64          f64_val, [r64_addr_in];
    add.f64         f64_sum, f64_sum, f64_val;
    add.u64         r64_idx, r64_idx, r64_stride;
    bra             LOOP;

LOOP_DONE:
    mov.u64         r64_sbase, sdata;
    mul.lo.u64      r64_saddr, r64_tid, 8;
    add.u64         r64_saddr, r64_sbase, r64_saddr;
    st.shared.f64   [r64_saddr], f64_sum;

    bar.sync        0;

    shr.u32         r32_s, r32_ntid, 1;

REDUCE_LOOP:
    setp.le.u32     p, r32_s, 0;
