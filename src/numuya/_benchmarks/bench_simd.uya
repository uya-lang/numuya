// NumUya CPU benchmark for the fixed Phase 24 NumPy comparison matrix.
//
// This benchmark emits BENCH_JSON rows consumed by
// benchmarks/python/collect_numuya_benchmarks.py.

use array;
use creation;
use linalg;
use random;
use reductions;
use shape;
use ufunc;

use libc.syscall;
use std.mem.allocator.IAllocator;
use std.mem.allocator.MallocAllocator;

const CLOCK_MONOTONIC: i32 = 1;
const NS_PER_SEC: u64 = 1000000000u64;
const ELEMENT_WARMUP: usize = 5;
const ELEMENT_REPEAT: usize = 20;
const MATMUL_WARMUP: usize = 3;
const MATMUL_REPEAT: usize = 10;
const RANDOM_WARMUP: usize = 5;
const RANDOM_REPEAT: usize = 20;
const MAX_BENCH_SAMPLES: usize = 20;

extern "libc" fn snprintf(buf: &byte, size: usize, format: &const byte, ...) i32;

fn monotonic_ns() u64 {
    var ts: TimeSpec = TimeSpec{ tv_sec: 0, tv_nsec: 0 };
    _ = sys_clock_gettime(CLOCK_MONOTONIC, &ts) catch {
        return 0u64;
    };
    const sec: u64 = (ts.tv_sec as! u64).value;
    const nsec: u64 = (ts.tv_nsec as! u64).value;
    return sec * NS_PER_SEC + nsec;
}

fn write_str(text: &const byte) void {
    const len: usize = strlen(text);
    _ = sys_write(1, text, len) catch { return; };
}

fn write_byte(b: byte) void {
    _ = sys_write(1, &b, 1) catch { return; };
}

fn write_usize(value: usize) void {
    if value == 0 {
        write_str("0");
        return;
    }
    var digits: [byte: 32] = [];
    var digit_count: usize = 0;
    var remaining: usize = value;
    while remaining > 0 {
        const d: usize = remaining % (10 as usize);
        const zero: usize = 48;
        digits[digit_count] = ((zero + d) as! byte).value;
        digit_count = digit_count + 1;
        remaining = remaining / (10 as usize);
    }
    var i: usize = digit_count;
    while i > 0 {
        i = i - 1;
        write_byte(digits[i]);
    }
}

fn write_f64(value: f64, decimals: usize) void {
    var buf: [byte: 64] = [];
    if decimals == 0 {
        _ = snprintf(&buf[0], 64, "%f", value);
    } else if decimals == 1 {
        _ = snprintf(&buf[0], 64, "%.1f", value);
    } else if decimals == 2 {
        _ = snprintf(&buf[0], 64, "%.2f", value);
    } else if decimals == 3 {
        _ = snprintf(&buf[0], 64, "%.3f", value);
    } else if decimals == 4 {
        _ = snprintf(&buf[0], 64, "%.4f", value);
    } else if decimals == 6 {
        _ = snprintf(&buf[0], 64, "%.6f", value);
    } else {
        _ = snprintf(&buf[0], 64, "%.2f", value);
    }
    const len: usize = strlen(&buf[0]);
    _ = sys_write(1, &buf[0], len) catch { return; };
}

fn write_newline() void {
    write_str("\n");
}

fn print_header() void {
    write_str("Benchmark: NumUya CPU fixed matrix\n");
    write_str("==================================\n");
    write_str("This benchmark measures wall-clock time; it does not verify correctness.\n");
    write_str("Scope: fixed Phase 24 CPU matrix (add/mul/sum f32/f64, matmul/random f32).\n");
    write_str("For correctness, run `make test`.\n\n");
}

fn print_result(name: &const byte, scalar_ns: u64, simd_ns: u64, elements: usize, iterations: usize) void {
    const measured_ns: u64 = if simd_ns == 0 { scalar_ns } else { simd_ns };
    const per_iter: f64 = if iterations == 0 { 0.0 } else { (measured_ns as f64) / (iterations as f64) };
    const per_elem: f64 = if elements == 0 { 0.0 } else { per_iter / (elements as f64) };

    write_str(name);
    write_str(": per-iter=");
    write_f64(per_iter, 2);
    write_str(" ns (");
    write_f64(per_elem, 4);
    write_str(" ns/elem), iterations=");
    write_usize(iterations);
    write_newline();
}

fn print_samples(samples: &u64, repeat: usize) void {
    write_str("|samples_ns=");
    var i: usize = 0;
    while i < repeat {
        if i > 0 {
            write_str(",");
        }
        write_usize(samples[i] as usize);
        i = i + 1;
    }
}

fn print_json_result(
    operation: &const byte,
    dtype: &const byte,
    shape0: usize,
    shape1: usize,
    total_ns: u64,
    warmup: usize,
    repeat: usize,
    samples: &u64,
) void {
    write_str("BENCH_JSON|operation=");
    write_str(operation);
    write_str("|mode=cpu");
    write_str("|metric=latency");
    write_str("|dtype=");
    write_str(dtype);
    write_str("|shape=");
    write_usize(shape0);
    if shape1 > 0 {
        write_str("x");
        write_usize(shape1);
    }
    write_str("|warmup=");
    write_usize(warmup);
    write_str("|repeat=");
    write_usize(repeat);
    write_str("|iterations=");
    write_usize(repeat);
    write_str("|total_ns=");
    write_usize(total_ns as usize);
    print_samples(samples, repeat);
    write_newline();
}

fn warmup_add_f64(left: &Array<f64>, right: &Array<f64>, warmup: usize) !void {
    var i: usize = 0;
    while i < warmup {
        const result: Array<f64> = try add_f64(left, right);
        _ = result.storage.len;
        i = i + 1;
    }
}

fn warmup_add_f32(left: &Array<f32>, right: &Array<f32>, warmup: usize) !void {
    var i: usize = 0;
    while i < warmup {
        const result: Array<f32> = try add_f32(left, right);
        _ = result.storage.len;
        i = i + 1;
    }
}

fn warmup_mul_f64(left: &Array<f64>, right: &Array<f64>, warmup: usize) !void {
    var i: usize = 0;
    while i < warmup {
        const result: Array<f64> = try mul_f64(left, right);
        _ = result.storage.len;
        i = i + 1;
    }
}

fn warmup_mul_f32(left: &Array<f32>, right: &Array<f32>, warmup: usize) !void {
    var i: usize = 0;
    while i < warmup {
        const result: Array<f32> = try mul_f32(left, right);
        _ = result.storage.len;
        i = i + 1;
    }
}

fn warmup_sum_f64(input: &Array<f64>, warmup: usize) !void {
    var i: usize = 0;
    while i < warmup {
        const result: f64 = try sum_all_f64(input);
        _ = result;
        i = i + 1;
    }
}

fn warmup_sum_f32(input: &Array<f32>, warmup: usize) !void {
    var i: usize = 0;
    while i < warmup {
        const result: f32 = try sum_all_f32(input);
        _ = result;
        i = i + 1;
    }
}

fn warmup_matmul_f32(left: &Array<f32>, right: &Array<f32>, warmup: usize) !void {
    var i: usize = 0;
    while i < warmup {
        const result: Array<f32> = try matmul_f32(left, right);
        _ = result.storage.len;
        i = i + 1;
    }
}

fn warmup_random_f32(allocator: IAllocator, elements: usize, warmup: usize) !void {
    var rng: PCG64 = pcg64_seed(777u64, 3u64);
    var i: usize = 0;
    while i < warmup {
        const result: Array<f32> = try random_array_f32(allocator, &rng, shape1(elements));
        _ = result.storage.len;
        i = i + 1;
    }
}

fn bench_add_f64(left: &Array<f64>, right: &Array<f64>, samples: &u64, repeat: usize) !u64 {
    var total: u64 = 0u64;
    var i: usize = 0;
    while i < repeat {
        const start: u64 = monotonic_ns();
        const result: Array<f64> = try add_f64(left, right);
        _ = result.storage.len;
        const elapsed: u64 = monotonic_ns() - start;
        samples[i] = elapsed;
        total = total + elapsed;
        i = i + 1;
    }
    return total;
}

fn bench_add_f32(left: &Array<f32>, right: &Array<f32>, samples: &u64, repeat: usize) !u64 {
    var total: u64 = 0u64;
    var i: usize = 0;
    while i < repeat {
        const start: u64 = monotonic_ns();
        const result: Array<f32> = try add_f32(left, right);
        _ = result.storage.len;
        const elapsed: u64 = monotonic_ns() - start;
        samples[i] = elapsed;
        total = total + elapsed;
        i = i + 1;
    }
    return total;
}

