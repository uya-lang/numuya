fn bench_random_f32(allocator: IAllocator, elements: usize, samples: &u64, repeat: usize) !u64 {
    var rng: PCG64 = pcg64_seed(12345u64, 1u64);
    var total: u64 = 0u64;
    var i: usize = 0;
    while i < repeat {
        const start: u64 = monotonic_ns();
        const result: Array<f32> = try random_array_f32(allocator, &rng, shape1(elements));
        _ = result.storage.len;
        const elapsed: u64 = monotonic_ns() - start;
        samples[i] = elapsed;
        total = total + elapsed;
        i = i + 1;
    }
    return total;
}

fn run_element_case(allocator: IAllocator, elements: usize) !void {
    const warmup: usize = ELEMENT_WARMUP;
    const repeat: usize = ELEMENT_REPEAT;

    var left_f64: Array<f64> = try full_f64(allocator, shape1(elements), 1.5);
    var right_f64: Array<f64> = try full_f64(allocator, shape1(elements), 2.5);
    var left_f32: Array<f32> = try full<f32>(allocator, shape1(elements), 1.5);
    var right_f32: Array<f32> = try full<f32>(allocator, shape1(elements), 2.5);
    var samples: [u64: MAX_BENCH_SAMPLES] = [0u64: MAX_BENCH_SAMPLES];

    try warmup_add_f64(&left_f64, &right_f64, warmup);
    const add_f64_ns: u64 = try bench_add_f64(&left_f64, &right_f64, &samples[0], repeat);
    print_result("add_f64", 0u64, add_f64_ns, elements, repeat);
    print_json_result("add", "float64", elements, 0, add_f64_ns, warmup, repeat, &samples[0]);

    try warmup_add_f32(&left_f32, &right_f32, warmup);
    const add_f32_ns: u64 = try bench_add_f32(&left_f32, &right_f32, &samples[0], repeat);
    print_result("add_f32", 0u64, add_f32_ns, elements, repeat);
    print_json_result("add", "float32", elements, 0, add_f32_ns, warmup, repeat, &samples[0]);

    try warmup_mul_f64(&left_f64, &right_f64, warmup);
    const mul_f64_ns: u64 = try bench_mul_f64(&left_f64, &right_f64, &samples[0], repeat);
    print_result("mul_f64", 0u64, mul_f64_ns, elements, repeat);
    print_json_result("mul", "float64", elements, 0, mul_f64_ns, warmup, repeat, &samples[0]);

    try warmup_mul_f32(&left_f32, &right_f32, warmup);
    const mul_f32_ns: u64 = try bench_mul_f32(&left_f32, &right_f32, &samples[0], repeat);
    print_result("mul_f32", 0u64, mul_f32_ns, elements, repeat);
    print_json_result("mul", "float32", elements, 0, mul_f32_ns, warmup, repeat, &samples[0]);

    try warmup_sum_f64(&left_f64, warmup);
    const sum_f64_ns: u64 = try bench_sum_f64(&left_f64, &samples[0], repeat);
    print_result("sum_all_f64", 0u64, sum_f64_ns, elements, repeat);
    print_json_result("sum", "float64", elements, 0, sum_f64_ns, warmup, repeat, &samples[0]);

    try warmup_sum_f32(&left_f32, warmup);
    const sum_f32_ns: u64 = try bench_sum_f32(&left_f32, &samples[0], repeat);
    print_result("sum_all_f32", 0u64, sum_f32_ns, elements, repeat);
    print_json_result("sum", "float32", elements, 0, sum_f32_ns, warmup, repeat, &samples[0]);
}

fn run_matmul_case(allocator: IAllocator, size: usize) !void {
    const warmup: usize = MATMUL_WARMUP;
    const repeat: usize = MATMUL_REPEAT;
    var left: Array<f32> = try full<f32>(allocator, shape2(size, size), 1.0);
    var right: Array<f32> = try full<f32>(allocator, shape2(size, size), 1.0);
    var samples: [u64: MAX_BENCH_SAMPLES] = [0u64: MAX_BENCH_SAMPLES];

    try warmup_matmul_f32(&left, &right, warmup);
    const total_ns: u64 = try bench_matmul_f32(&left, &right, &samples[0], repeat);
    print_result("matmul_f32", 0u64, total_ns, size * size, repeat);
    print_json_result("matmul", "float32", size, size, total_ns, warmup, repeat, &samples[0]);
}

fn run_random_case(allocator: IAllocator, elements: usize) !void {
    const warmup: usize = RANDOM_WARMUP;
    const repeat: usize = RANDOM_REPEAT;
    var samples: [u64: MAX_BENCH_SAMPLES] = [0u64: MAX_BENCH_SAMPLES];

    try warmup_random_f32(allocator, elements, warmup);
    const total_ns: u64 = try bench_random_f32(allocator, elements, &samples[0], repeat);
    print_result("random_f32", 0u64, total_ns, elements, repeat);
    print_json_result("random", "float32", elements, 0, total_ns, warmup, repeat, &samples[0]);
}

export fn main() i32 {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;

    print_header();

    run_element_case(allocator, 10000) catch {
        write_str("error: element benchmark 10000 failed\n");
        return 1;
    };
    run_element_case(allocator, 1000000) catch {
        write_str("error: element benchmark 1000000 failed\n");
        return 1;
    };
    run_element_case(allocator, 10000000) catch {
        write_str("error: element benchmark 10000000 failed\n");
        return 1;
    };

    run_matmul_case(allocator, 256) catch {
        write_str("error: matmul_f32 256 benchmark failed\n");
        return 1;
    };
    run_matmul_case(allocator, 1024) catch {
        write_str("error: matmul_f32 1024 benchmark failed\n");
        return 1;
    };
    run_matmul_case(allocator, 2048) catch {
        write_str("error: matmul_f32 2048 benchmark failed\n");
        return 1;
    };

    run_random_case(allocator, 1000000) catch {
        write_str("error: random_f32 1000000 benchmark failed\n");
        return 1;
    };
    run_random_case(allocator, 10000000) catch {
        write_str("error: random_f32 10000000 benchmark failed\n");
        return 1;
    };

    write_newline();
    write_str("Done.\n");
    return 0;
}
