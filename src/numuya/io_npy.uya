use array;
use creation;
use shape;
use storage;

use std.io.File;
use std.io.file_close;
use std.io.file_open;
use std.io.file_read;
use std.io.file_write;
use std.mem.mem_copy;
use std.mem.allocator.IAllocator;
use std.string.strlen;

use libc.O_RDONLY;
use libc.O_WRONLY;
use libc.O_CREAT;
use libc.O_TRUNC;
use libc.SEEK_END;
use libc.SEEK_SET;
use libc.lseek;

const NPY_HEADER_ALIGNMENT: usize = 16;
const NPY_MAGIC_LEN: usize = 6;
const NPY_VERSION_LEN: usize = 2;
const NPY_F64_SIZE: usize = 8;
const NPY_V1_HEADER_LEN_BYTES: usize = 2;
const NPY_V2_HEADER_LEN_BYTES: usize = 4;
const NPY_V1_MAX_HEADER_LEN: usize = 65535;
const NPY_WRITE_FILE_MODE: u32 = 0o644;
const NPY_WRITE_HEADER_CAPACITY: usize = 512;

struct NpyVersion {
    major: byte,
    minor: byte,
}

struct NpyArrayMetadata {
    version: NpyVersion,
    fortran_order: bool,
    shape: Shape,
}

fn npy_magic_byte(index: usize) !byte {
    if index == 0 {
        return (147 as! byte).value;
    }
    if index == 1 {
        return (78 as! byte).value;
    }
    if index == 2 {
        return (85 as! byte).value;
    }
    if index == 3 {
        return (77 as! byte).value;
    }
    if index == 4 {
        return (80 as! byte).value;
    }
    if index == 5 {
        return (89 as! byte).value;
    }
    return error.NumuyaIndexOutOfBounds;
}

fn npy_header_len_size(version: &NpyVersion) !usize {
    if version.major == (1 as byte) && version.minor == (0 as byte) {
        return NPY_V1_HEADER_LEN_BYTES;
    }
    if version.major == (2 as byte) && version.minor == (0 as byte) {
        return NPY_V2_HEADER_LEN_BYTES;
    }
    return error.NumuyaInvalidArgument;
}

fn npy_header_padding(prefix_len: usize, header_len: usize) usize {
    const total: usize = prefix_len + header_len + 1;
    const remainder: usize = total % NPY_HEADER_ALIGNMENT;
    if remainder == 0 {
        return 0;
    }
    return NPY_HEADER_ALIGNMENT - remainder;
}

fn npy_validate_c_order(metadata: &NpyArrayMetadata) !void {
    if metadata.fortran_order == true {
        return error.NumuyaInvalidArgument;
    }
    return;
}

fn npy_shape_size(metadata: &NpyArrayMetadata) !usize {
    return shape_size(metadata.shape);
}

fn npy_empty_metadata() NpyArrayMetadata {
    return NpyArrayMetadata{
        version: NpyVersion{
            major: 0 as byte,
            minor: 0 as byte,
        },
        fortran_order: false,
        shape: shape_scalar(),
    };
}

fn npy_read_exact(file: &File, buf: &byte, count: usize) !void {
    var filled: usize = 0;
    while filled < count {
        const chunk: isize = file_read(file, &buf[filled], count - filled);
        if chunk <= 0 {
            return error.NumuyaInvalidArgument;
        }
        const read_len: usize = chunk as! usize catch {
            return error.NumuyaInvalidArgument;
        };
        filled = filled + read_len;
    }
}

fn npy_write_exact(file: &File, buf: &const byte, count: usize) !void {
    var written: usize = 0;
    while written < count {
        const chunk: usize = try file_write(file, &buf[written], count - written);
        if chunk == 0 {
            return error.NumuyaInvalidArgument;
        }
        written = written + chunk;
    }
}

fn npy_file_size(file: &File) !usize {
    const end_offset: i64 = lseek(file.fd, 0, SEEK_END);
    if end_offset < 0 {
        return error.NumuyaInvalidArgument;
    }
    const size: usize = end_offset as! usize catch {
        return error.NumuyaInvalidArgument;
    };
    if lseek(file.fd, 0, SEEK_SET) < 0 {
        return error.NumuyaInvalidArgument;
    }
    return size;
}

fn npy_append_byte(buf: &byte, capacity: usize, len: &usize, value: byte) !void {
    if len[0] >= capacity {
        return error.NumuyaInvalidArgument;
    }
    buf[len[0]] = value;
    len[0] = len[0] + 1;
}

fn npy_append_text(buf: &byte, capacity: usize, len: &usize, text: &const byte) !void {
    const text_len: usize = strlen(text);
    if len[0] + text_len > capacity {
        return error.NumuyaInvalidArgument;
    }

    var i: usize = 0;
    while i < text_len {
        buf[len[0] + i] = text[i];
        i = i + 1;
    }
    len[0] = len[0] + text_len;
}

fn npy_append_usize_decimal(buf: &byte, capacity: usize, len: &usize, value: usize) !void {
    if value == 0 {
        try npy_append_byte(buf, capacity, len, 48 as byte);
        return;
    }

    var digits: [byte: 32] = [];
    var digit_count: usize = 0;
    var remaining: usize = value;
    while remaining > 0 {
        digits[digit_count] = ((((remaining % 10) as u32) + 48) as! byte).value;
        digit_count = digit_count + 1;
        remaining = remaining / 10;
    }

    while digit_count > 0 {
        digit_count = digit_count - 1;
        try npy_append_byte(buf, capacity, len, digits[digit_count]);
    }
}

fn npy_append_shape(buf: &byte, capacity: usize, len: &usize, shape_value: &Shape) !void {
    try npy_append_byte(buf, capacity, len, 40 as byte);

    if shape_value.rank == 0 {
        try npy_append_byte(buf, capacity, len, 41 as byte);
        return;
    }

    var axis: usize = 0;
    while axis < shape_value.rank {
        try npy_append_usize_decimal(buf, capacity, len, shape_value.dims[axis]);
        if shape_value.rank == 1 {
            try npy_append_byte(buf, capacity, len, 44 as byte);
        } else if axis + 1 < shape_value.rank {
            try npy_append_text(buf, capacity, len, ", ");
        }
        axis = axis + 1;
    }

    try npy_append_byte(buf, capacity, len, 41 as byte);
}

fn npy_build_f64_header(shape_value: &Shape, header: &byte, capacity: usize) !usize {
    var header_len: usize = 0;
    try npy_append_text(header, capacity, &header_len, "{'descr': '<f8', 'fortran_order': False, 'shape': ");
    try npy_append_shape(header, capacity, &header_len, shape_value);
    try npy_append_text(header, capacity, &header_len, ", }");

    const prefix_len: usize = NPY_MAGIC_LEN + NPY_VERSION_LEN + NPY_V1_HEADER_LEN_BYTES;
    const padding: usize = npy_header_padding(prefix_len, header_len);

    var i: usize = 0;
    while i < padding {
        try npy_append_byte(header, capacity, &header_len, 32 as byte);
        i = i + 1;
    }
    try npy_append_byte(header, capacity, &header_len, 10 as byte);
    return header_len;
}

fn npy_validate_magic(data: &byte, len: usize) !void {
    if len < NPY_MAGIC_LEN + NPY_VERSION_LEN {
        return error.NumuyaInvalidArgument;
    }

    var i: usize = 0;
    while i < NPY_MAGIC_LEN {
        if data[i] != try npy_magic_byte(i) {
            return error.NumuyaInvalidArgument;
        }
        i = i + 1;
    }
}

fn npy_read_version(data: &byte, len: usize) !NpyVersion {
    if len < NPY_MAGIC_LEN + NPY_VERSION_LEN {
        return error.NumuyaInvalidArgument;
    }
    return NpyVersion{
        major: data[NPY_MAGIC_LEN],
        minor: data[NPY_MAGIC_LEN + 1],
    };
}

fn npy_read_header_len(data: &byte, len: usize, version: &NpyVersion) !usize {
    const header_len_size: usize = try npy_header_len_size(version);
    const header_len_offset: usize = NPY_MAGIC_LEN + NPY_VERSION_LEN;
    if header_len_offset + header_len_size > len {
        return error.NumuyaInvalidArgument;
    }

    if header_len_size == NPY_V1_HEADER_LEN_BYTES {
        const low: usize = data[header_len_offset] as usize;
        const high: usize = (data[header_len_offset + 1] as usize) << 8;
        return low | high;
    }

    const value: u32 =
        (data[header_len_offset] as u32) |
        ((data[header_len_offset + 1] as u32) << 8) |
        ((data[header_len_offset + 2] as u32) << 16) |
        ((data[header_len_offset + 3] as u32) << 24);
    return value as usize;
}

fn npy_match_string_at(data: &byte, len: usize, offset: usize, text: &const byte) bool {
    const text_len: usize = strlen(text);
    if offset + text_len > len {
        return false;
    }

    var i: usize = 0;
    while i < text_len {
        if data[offset + i] != text[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn npy_find_string(data: &byte, len: usize, text: &const byte) !usize {
    const text_len: usize = strlen(text);
    if text_len == 0 || text_len > len {
        return error.NumuyaInvalidArgument;
    }

    var offset: usize = 0;
    while offset + text_len <= len {
        if npy_match_string_at(data, len, offset, text) {
            return offset;
        }
        offset = offset + 1;
    }
    return error.NumuyaInvalidArgument;
}

fn npy_header_value_start(header: &byte, header_len: usize, key: &const byte) !usize {
    const key_offset: usize = try npy_find_string(header, header_len, key);
    var cursor: usize = key_offset + strlen(key);
    while cursor < header_len {
        const ch: byte = header[cursor];
        if ch == 32 as byte || ch == 58 as byte {
            cursor = cursor + 1;
            continue;
        }
        return cursor;
    }
    return error.NumuyaInvalidArgument;
}

fn npy_validate_f64_descr(header: &byte, header_len: usize) !void {
    const value_offset: usize = try npy_header_value_start(header, header_len, "'descr'");
    if value_offset + 5 > header_len {
        return error.NumuyaInvalidArgument;
    }
    if header[value_offset] != 39 as byte || header[value_offset + 4] != 39 as byte {
        return error.NumuyaInvalidArgument;
    }
    if header[value_offset + 1] == 60 as byte &&
        header[value_offset + 2] == 102 as byte &&
        header[value_offset + 3] == 56 as byte {
        return;
    }
    return error.NumuyaUnsupportedDType;
}

fn npy_parse_fortran_order(header: &byte, header_len: usize) !bool {
    const value_offset: usize = try npy_header_value_start(header, header_len, "'fortran_order'");
    if npy_match_string_at(header, header_len, value_offset, "False") {
        return false;
    }
    if npy_match_string_at(header, header_len, value_offset, "True") {
        return true;
    }
    return error.NumuyaInvalidArgument;
}

fn npy_parse_shape_dim(header: &byte, header_len: usize, cursor: &usize) !usize {
    if cursor[0] >= header_len {
        return error.NumuyaInvalidArgument;
    }

    const zero: byte = 48 as byte;
    const nine: byte = 57 as byte;
    if header[cursor[0]] < zero || header[cursor[0]] > nine {
        return error.NumuyaInvalidArgument;
    }

    var value: usize = 0;
    while cursor[0] < header_len {
        const ch: byte = header[cursor[0]];
        if ch < zero || ch > nine {
            break;
        }
        value = value * 10 + ((ch - zero) as usize);
        cursor[0] = cursor[0] + 1;
    }
    return value;
}

fn npy_parse_shape(header: &byte, header_len: usize) !Shape {
    const value_offset: usize = try npy_header_value_start(header, header_len, "'shape'");
    if value_offset >= header_len || header[value_offset] != 40 as byte {
        return error.NumuyaInvalidArgument;
    }

    var dims: [usize: NUMUYA_MAX_DIMS] = [0: NUMUYA_MAX_DIMS];
    var rank: usize = 0;
    var cursor: usize = value_offset + 1;

    while cursor < header_len {
        while cursor < header_len && header[cursor] == 32 as byte {
            cursor = cursor + 1;
        }
        if cursor >= header_len {
            return error.NumuyaInvalidArgument;
        }
        if header[cursor] == 41 as byte {
            return Shape{ rank: rank, dims: dims };
        }
        if rank >= NUMUYA_MAX_DIMS {
            return error.NumuyaRankTooLarge;
        }

        dims[rank] = try npy_parse_shape_dim(header, header_len, &cursor);
        rank = rank + 1;

        while cursor < header_len && header[cursor] == 32 as byte {
            cursor = cursor + 1;
        }
        if cursor >= header_len {
            return error.NumuyaInvalidArgument;
        }
        if header[cursor] == 44 as byte {
            cursor = cursor + 1;
            continue;
        }
        if header[cursor] == 41 as byte {
            return Shape{ rank: rank, dims: dims };
        }
        return error.NumuyaInvalidArgument;
    }

    return error.NumuyaInvalidArgument;
}

fn npy_parse_metadata(data: &byte, len: usize) !NpyArrayMetadata {
    try npy_validate_magic(data, len);

    const version: NpyVersion = try npy_read_version(data, len);
    const header_len_size: usize = try npy_header_len_size(&version);
    const header_len: usize = try npy_read_header_len(data, len, &version);
    const header_offset: usize = NPY_MAGIC_LEN + NPY_VERSION_LEN + header_len_size;
    if header_offset + header_len > len {
        return error.NumuyaInvalidArgument;
    }

    const header: &byte = &data[header_offset];
    try npy_validate_f64_descr(header, header_len);

    return NpyArrayMetadata{
        version: version,
        fortran_order: try npy_parse_fortran_order(header, header_len),
        shape: try npy_parse_shape(header, header_len),
    };
}

export fn save_npy_f64(path: &const byte, array_value: &Array<f64>) !void {
    if array_is_c_contiguous<f64>(array_value) != true {
        return error.NumuyaInvalidArgument;
    }

    const offset: usize = array_value.offset as! usize catch {
        return error.NumuyaInvalidArgument;
    };
    const element_count: usize = array_size<f64>(array_value);
    if offset > array_value.storage.len || element_count > array_value.storage.len - offset {
        return error.NumuyaInvalidArgument;
    }

    var header: [byte: NPY_WRITE_HEADER_CAPACITY] = [];
    const header_len: usize = try npy_build_f64_header(&array_value.shape, &header[0], NPY_WRITE_HEADER_CAPACITY);
    if header_len > NPY_V1_MAX_HEADER_LEN {
        return error.NumuyaInvalidArgument;
    }

    var prefix: [byte: NPY_MAGIC_LEN + NPY_VERSION_LEN + NPY_V1_HEADER_LEN_BYTES] = [];
    var i: usize = 0;
    while i < NPY_MAGIC_LEN {
        prefix[i] = try npy_magic_byte(i);
        i = i + 1;
    }
    prefix[NPY_MAGIC_LEN] = 1 as byte;
    prefix[NPY_MAGIC_LEN + 1] = 0 as byte;
    prefix[NPY_MAGIC_LEN + NPY_VERSION_LEN] = (header_len & 255usize) as! byte catch {
        return error.NumuyaInvalidArgument;
    };
    prefix[NPY_MAGIC_LEN + NPY_VERSION_LEN + 1] = ((header_len >> 8) & 255usize) as! byte catch {
        return error.NumuyaInvalidArgument;
    };

    var file: File = try file_open(path, (O_WRONLY | O_CREAT | O_TRUNC) as i32, NPY_WRITE_FILE_MODE);
    errdefer {
        _ = file_close(&file) catch {};
    }

    try npy_write_exact(&file, &prefix[0], @len(prefix));
    try npy_write_exact(&file, &header[0], header_len);

    if element_count > 0 {
        try npy_write_exact(
            &file,
            &array_value.storage.data[offset] as &const byte,
            element_count * NPY_F64_SIZE,
        );
    }

    try file_close(&file);
}

export fn load_npy_f64(allocator: IAllocator, path: &const byte) !Array<f64> {
    var file: File = try file_open(path, O_RDONLY as i32, 0);
    errdefer {
        _ = file_close(&file) catch {};
    }

    const file_size: usize = try npy_file_size(&file);
    const file_bytes: &byte = try allocator.alloc(file_size);
    errdefer {
        allocator.dealloc(file_bytes);
    }

    try npy_read_exact(&file, file_bytes, file_size);
    try file_close(&file);

    const metadata: NpyArrayMetadata = try npy_parse_metadata(file_bytes, file_size);
    try npy_validate_c_order(&metadata);

    const header_len_size: usize = try npy_header_len_size(&metadata.version);
    const header_len: usize = try npy_read_header_len(file_bytes, file_size, &metadata.version);
    const data_offset: usize = NPY_MAGIC_LEN + NPY_VERSION_LEN + header_len_size + header_len;
    if data_offset > file_size {
        return error.NumuyaInvalidArgument;
    }

    const data_len: usize = file_size - data_offset;
    if data_len % NPY_F64_SIZE != 0 {
        return error.NumuyaInvalidArgument;
    }

    const element_count: usize = try npy_shape_size(&metadata);
    if data_len / NPY_F64_SIZE != element_count {
        return error.NumuyaInvalidArgument;
    }

    var result: Array<f64> = try full_f64(allocator, metadata.shape, 0.0);
    if data_len > 0 {
        mem_copy(result.storage.data as &byte, &file_bytes[data_offset], data_len);
    }

    storage_retain<f64>(result.storage);
    return Array<f64>{
        storage: result.storage,
        offset: result.offset,
        shape: result.shape,
        strides: result.strides,
        flags: result.flags,
    };
}
