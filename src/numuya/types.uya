export fn array_any_shape(any_value: &ArrayAny) Shape {
    return any_value.shape;
}

export fn array_any_try_as_f64(any_value: &ArrayAny) !Array<f64> {
    if any_value.dtype != dtype_f64() {
        return error.NumuyaUnsupportedDType;
    }
    return array_any_copy_payload_view(any_value);
}

export fn array_any_try_as_f32(any_value: &ArrayAny) !Array<f32> {
    if any_value.dtype != dtype_f32() {
        return error.NumuyaUnsupportedDType;
    }
    var result: Array<f32> = try empty<f32>(any_value.payload.storage.allocator, any_value.shape);
    const size: usize = array_size<f64>(&any_value.payload);
    var i: usize = 0;
    while i < size {
        result.storage.data[i] = any_value.payload.storage.data[i] as f32;
        i = i + 1;
    }
    storage_retain<f32>(result.storage);
    return Array<f32>{
        storage: result.storage,
        offset: result.offset,
        shape: result.shape,
        strides: result.strides,
        flags: result.flags,
    };
}

