use array;
use creation;
use shape;
use storage;

use std.mem.allocator.IAllocator;

export enum DTypeKind {
    Float,
    Signed,
    Unsigned,
}

export enum Endian {
    Little,
}

export enum DType {
    F64,
    F32,
    I64,
    I32,
    U8,
}

export fn dtype_f64() DType {
    return DType.F64;
}

export fn dtype_f32() DType {
    return DType.F32;
}

export fn dtype_i64() DType {
    return DType.I64;
}

export fn dtype_i32() DType {
    return DType.I32;
}

export fn dtype_u8() DType {
    return DType.U8;
}

export fn dtype_size(dt: DType) usize {
    match dt {
        DType.F64 => { return 8; }
        DType.F32 => { return 4; }
        DType.I64 => { return 8; }
        DType.I32 => { return 4; }
        DType.U8 => { return 1; }
        else => { return 0; }
    }
}

export fn dtype_name(dt: DType) &const byte {
    match dt {
        DType.F64 => { return "f64" as &const byte; }
        DType.F32 => { return "f32" as &const byte; }
        DType.I64 => { return "i64" as &const byte; }
        DType.I32 => { return "i32" as &const byte; }
        DType.U8 => { return "u8" as &const byte; }
        else => { return "" as &const byte; }
    }
}

export fn dtype_kind(dt: DType) DTypeKind {
    match dt {
        DType.F64 => { return DTypeKind.Float; }
        DType.F32 => { return DTypeKind.Float; }
        DType.I64 => { return DTypeKind.Signed; }
        DType.I32 => { return DTypeKind.Signed; }
        DType.U8 => { return DTypeKind.Unsigned; }
        else => { return DTypeKind.Float; }
    }
}

export fn dtype_endian(dt: DType) Endian {
    return Endian.Little;
}

export struct ArrayAny {
    dtype: DType,
    shape: Shape,
    payload: Array<f64>,
}

fn array_any_copy_payload_view(any_value: &ArrayAny) Array<f64> {
    storage_retain<f64>(any_value.payload.storage);
    return Array<f64>{
        storage: any_value.payload.storage,
        offset: any_value.payload.offset,
        shape: any_value.payload.shape,
        strides: any_value.payload.strides,
        flags: any_value.payload.flags,
    };
}

export fn array_any_from_f64(array_value: &Array<f64>) ArrayAny {
    storage_retain<f64>(array_value.storage);
    return ArrayAny{
        dtype: dtype_f64(),
        shape: array_value.shape,
        payload: Array<f64>{
            storage: array_value.storage,
            offset: array_value.offset,
            shape: array_value.shape,
            strides: array_value.strides,
            flags: array_value.flags,
        },
    };
}

export fn array_any_from_f32(array_value: &Array<f32>) !ArrayAny {
    var f64_array: Array<f64> = try empty<f64>(array_value.storage.allocator, array_value.shape);
    const size: usize = array_size<f32>(array_value);
    var i: usize = 0;
    while i < size {
        f64_array.storage.data[i] = array_value.storage.data[i] as f64;
        i = i + 1;
    }
    storage_retain<f64>(f64_array.storage);
    return ArrayAny{
        dtype: dtype_f32(),
        shape: f64_array.shape,
        payload: Array<f64>{
            storage: f64_array.storage,
            offset: f64_array.offset,
            shape: f64_array.shape,
            strides: f64_array.strides,
            flags: f64_array.flags,
        },
    };
}

