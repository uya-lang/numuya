test "sin_f64 computes element-wise sine" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 4] = [0.0, NUMUYA_PI / 2.0, NUMUYA_PI, 3.0 * NUMUYA_PI / 2.0];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:4], shape1(4));

    var result: Array<f64> = try sin_f64(&input);

    try expect_eq_usize(result.shape.rank, 1);
    try expect_eq_usize(result.shape.dims[0], 4);
    try expect_close_f64(try get1<f64>(&result, 0), 0.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 1.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), 0.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 3), -1.0, 1e-12);
}

test "cos_f64 computes element-wise cosine" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 4] = [0.0, NUMUYA_PI / 2.0, NUMUYA_PI, 3.0 * NUMUYA_PI / 2.0];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:4], shape1(4));

    var result: Array<f64> = try cos_f64(&input);

    try expect_eq_usize(result.shape.rank, 1);
    try expect_eq_usize(result.shape.dims[0], 4);
    try expect_close_f64(try get1<f64>(&result, 0), 1.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 0.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), -1.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 3), 0.0, 1e-12);
}

test "math_f64 handles rank-2 contiguous arrays" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 6] = [-1.0, 4.0, 9.0, -16.0, 25.0, 36.0];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:6], shape2(2, 3));

    var result: Array<f64> = try sqrt_f64(&input);

    try expect_eq_usize(result.shape.rank, 2);
    try expect_eq_usize(result.shape.dims[0], 2);
    try expect_eq_usize(result.shape.dims[1], 3);
    try expect_close_f64(try get2<f64>(&result, 0, 0), 1.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 0, 1), 2.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 0, 2), 3.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 0), 4.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 1), 5.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 2), 6.0, 1e-12);
}

test "math_f64 handles non-contiguous transpose input" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 6] = [1.0, 4.0, 9.0, 16.0, 25.0, 36.0];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:6], shape2(2, 3));
    var transposed: Array<f64> = try transpose<f64>(&original);

    var result: Array<f64> = try sqrt_f64(&transposed);

    try expect_eq_usize(result.shape.rank, 2);
    try expect_eq_usize(result.shape.dims[0], 3);
    try expect_eq_usize(result.shape.dims[1], 2);
    try expect_close_f64(try get2<f64>(&result, 0, 0), 1.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 0, 1), 4.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 0), 2.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 1), 5.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 2, 0), 3.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 2, 1), 6.0, 1e-12);
}

test "math_f64 output is a new owner independent of input" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 3] = [-1.0, 2.0, -3.0];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:3], shape1(3));

    var result: Array<f64> = try abs_f64(&input);

    try expect_eq_usize(result.storage.ref_count, 1);
    if result.flags.owns_data != true {
        return error.NumuyaExpectationFailed;
    }

    try set1<f64>(&result, 0, 99.0);

    try expect_close_f64(try get1<f64>(&input, 0), -1.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 0), 99.0, 1e-12);
}
