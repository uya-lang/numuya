use array;
use creation;
use indexing;
use math;
use shape;
use stride;
use storage;
use testing.expect_close_f64;
use testing.expect_eq_usize;

use std.mem.allocator.IAllocator;
use std.mem.allocator.MallocAllocator;

const NUMUYA_PI: f64 = 3.14159265358979323846;

test "math test file imports math module" {
}

test "abs_f64 computes element-wise absolute value" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 4] = [-1.0, 0.0, 2.5, -3.75];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:4], shape1(4));

    var result: Array<f64> = try abs_f64(&input);

    try expect_eq_usize(result.shape.rank, 1);
    try expect_eq_usize(result.shape.dims[0], 4);
    try expect_close_f64(try get1<f64>(&result, 0), 1.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 0.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), 2.5, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 3), 3.75, 1e-12);
}

test "sqrt_f64 computes element-wise square root" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 4] = [0.0, 1.0, 4.0, 9.0];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:4], shape1(4));

    var result: Array<f64> = try sqrt_f64(&input);

    try expect_eq_usize(result.shape.rank, 1);
    try expect_eq_usize(result.shape.dims[0], 4);
    try expect_close_f64(try get1<f64>(&result, 0), 0.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 1.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), 2.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 3), 3.0, 1e-12);
}

test "exp_f64 computes element-wise natural exponential" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 3] = [0.0, 1.0, 2.0];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:3], shape1(3));

    var result: Array<f64> = try exp_f64(&input);

    try expect_eq_usize(result.shape.rank, 1);
    try expect_eq_usize(result.shape.dims[0], 3);
    try expect_close_f64(try get1<f64>(&result, 0), 1.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 2.718281828459045, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), 7.38905609893065, 1e-12);
}

