    }
}

test "maximum_f64 output is a new owner independent of inputs" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var left_data: [f64: 3] = [1.0, 5.0, 3.0];
    var right_data: [f64: 3] = [2.0, 4.0, 6.0];
    var left: Array<f64> = try from_slice<f64>(allocator, left_data[0:3], shape1(3));
    var right: Array<f64> = try from_slice<f64>(allocator, right_data[0:3], shape1(3));

    var result: Array<f64> = try maximum_f64(&left, &right);

    try expect_eq_usize(result.storage.ref_count, 1);
    if result.flags.owns_data != true {
        return error.NumuyaExpectationFailed;
    }

    try set1<f64>(&result, 0, 99.0);

    try expect_close_f64(try get1<f64>(&left, 0), 1.0, 1e-12);
    try expect_close_f64(try get1<f64>(&right, 0), 2.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 0), 99.0, 1e-12);
}

