    var right_data: [f64: 4] = [2.0, 4.0, 6.0, 7.0];
    var left: Array<f64> = try from_slice<f64>(allocator, left_data[0:4], shape1(4));
    var right: Array<f64> = try from_slice<f64>(allocator, right_data[0:4], shape1(4));

    var result: Array<f64> = try maximum_f64(&left, &right);

    try expect_eq_usize(result.shape.rank, 1);
    try expect_eq_usize(result.shape.dims[0], 4);
    try expect_close_f64(try get1<f64>(&result, 0), 2.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 5.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), 6.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 3), 8.0, 1e-12);
}

