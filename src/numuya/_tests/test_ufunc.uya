test "maximum_f64 handles non-contiguous transpose input" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 6] = [1.0, 5.0, 3.0, 2.0, 4.0, 6.0];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:6], shape2(2, 3));
    var transposed: Array<f64> = try transpose<f64>(&original);
    var other: Array<f64> = try full_f64(allocator, shape2(3, 2), 4.0);

    var result: Array<f64> = try maximum_f64(&transposed, &other);

    try expect_eq_usize(result.shape.rank, 2);
    try expect_eq_usize(result.shape.dims[0], 3);
    try expect_eq_usize(result.shape.dims[1], 2);
    try expect_close_f64(try get2<f64>(&result, 0, 0), 4.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 0, 1), 4.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 0), 5.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 1), 4.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 2, 0), 4.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 2, 1), 6.0, 1e-12);
}

test "minimum_f64 handles non-contiguous transpose input" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 6] = [1.0, 5.0, 3.0, 2.0, 4.0, 6.0];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:6], shape2(2, 3));
    var transposed: Array<f64> = try transpose<f64>(&original);
    var other: Array<f64> = try full_f64(allocator, shape2(3, 2), 4.0);

    var result: Array<f64> = try minimum_f64(&transposed, &other);

    try expect_eq_usize(result.shape.rank, 2);
    try expect_eq_usize(result.shape.dims[0], 3);
    try expect_eq_usize(result.shape.dims[1], 2);
    try expect_close_f64(try get2<f64>(&result, 0, 0), 1.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 0, 1), 2.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 0), 4.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 1), 4.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 2, 0), 3.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 2, 1), 4.0, 1e-12);
}

test "maximum_f64 propagates nan" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var left_data: [f64: 3] = [1.0, 0.0 / 0.0, 3.0];
    var right_data: [f64: 3] = [2.0, 4.0, 0.0 / 0.0];
    var left: Array<f64> = try from_slice<f64>(allocator, left_data[0:3], shape1(3));
    var right: Array<f64> = try from_slice<f64>(allocator, right_data[0:3], shape1(3));

    var result: Array<f64> = try maximum_f64(&left, &right);

    try expect_close_f64(try get1<f64>(&result, 0), 2.0, 1e-12);
    if (try get1<f64>(&result, 1)) == (try get1<f64>(&result, 1)) {
        return error.NumuyaExpectationFailed;
    }
    if (try get1<f64>(&result, 2)) == (try get1<f64>(&result, 2)) {
        return error.NumuyaExpectationFailed;
    }
}

