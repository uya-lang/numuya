use array;
use broadcast;
use creation;
use indexing;
use shape;
use storage;
use stride;
use testing.expect_close_f64;
use testing.expect_eq_usize;
use testing.expect_shape_eq;
use ufunc;

use std.mem.allocator.IAllocator;
use std.mem.allocator.MallocAllocator;

fn expect_eq_f32(actual: f32, expected: f32, tolerance: f32) !void {
    var diff: f32 = actual - expected;
    if diff < 0.0 {
        diff = 0.0 - diff;
    }
    if diff > tolerance {
        return error.NumuyaExpectationFailed;
    }
}

test "ufunc test file imports ufunc module" {
}

test "add_f64 computes element-wise sum for same shape" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var left_data: [f64: 3] = [1.0, 2.0, 3.0];
    var right_data: [f64: 3] = [4.0, 5.0, 6.0];
    var left: Array<f64> = try from_slice<f64>(allocator, left_data[0:3], shape1(3));
    var right: Array<f64> = try from_slice<f64>(allocator, right_data[0:3], shape1(3));

    var result: Array<f64> = try add_f64(&left, &right);

    try expect_eq_usize(result.shape.rank, 1);
    try expect_eq_usize(result.shape.dims[0], 3);
    try expect_close_f64(try get1<f64>(&result, 0), 5.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 7.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), 9.0, 1e-12);
}

test "sub_f64 computes element-wise difference for same shape" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var left_data: [f64: 3] = [4.0, 5.0, 6.0];
    var right_data: [f64: 3] = [1.0, 2.0, 3.0];
    var left: Array<f64> = try from_slice<f64>(allocator, left_data[0:3], shape1(3));
    var right: Array<f64> = try from_slice<f64>(allocator, right_data[0:3], shape1(3));

    var result: Array<f64> = try sub_f64(&left, &right);

    try expect_close_f64(try get1<f64>(&result, 0), 3.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 3.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), 3.0, 1e-12);
}

test "mul_f64 computes element-wise product for same shape" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var left_data: [f64: 3] = [2.0, 3.0, 4.0];
    var right_data: [f64: 3] = [5.0, 6.0, 7.0];
    var left: Array<f64> = try from_slice<f64>(allocator, left_data[0:3], shape1(3));
    var right: Array<f64> = try from_slice<f64>(allocator, right_data[0:3], shape1(3));

    var result: Array<f64> = try mul_f64(&left, &right);

    try expect_close_f64(try get1<f64>(&result, 0), 10.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 1), 18.0, 1e-12);
    try expect_close_f64(try get1<f64>(&result, 2), 28.0, 1e-12);
}

