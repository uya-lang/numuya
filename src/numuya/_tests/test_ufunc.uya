test "where_f64 broadcasts scalar x and y with matrix condition" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var cond_data: [bool: 4] = [true, false, false, true];
    var cond: Array<bool> = try from_slice<bool>(allocator, cond_data[0:4], shape2(2, 2));
    var x: Array<f64> = try full_f64(allocator, shape_scalar(), 5.0);
    var y: Array<f64> = try full_f64(allocator, shape_scalar(), -5.0);

    var result: Array<f64> = try where_f64(&cond, &x, &y);

    try expect_eq_usize(result.shape.rank, 2);
    try expect_eq_usize(result.shape.dims[0], 2);
    try expect_eq_usize(result.shape.dims[1], 2);
    try expect_close_f64(try get2<f64>(&result, 0, 0), 5.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 0, 1), -5.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 0), -5.0, 1e-12);
    try expect_close_f64(try get2<f64>(&result, 1, 1), 5.0, 1e-12);
}

test "maximum_f64 computes element-wise maximum for same shape" {
