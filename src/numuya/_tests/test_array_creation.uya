test "creation convenience constructors fill expected f64 values" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;

    const zeros_value: Array<f64> = try zeros_f64(allocator, shape2(2, 2));
    const ones_value: Array<f64> = try ones_f64(allocator, shape2(2, 2));
    const scalar_full: Array<f64> = try full_f64(allocator, shape_scalar(), 3.5);
    const full_value: Array<f64> = try full_f64(allocator, shape1(0), 1.25);

    storage_retain<f64>(scalar_full.storage);
    storage_release<f64>(scalar_full.storage);

    try expect_eq_usize(array_rank<f64>(&zeros_value), 2);
    try expect_eq_usize(array_rank<f64>(&ones_value), 2);
    try expect_eq_usize(array_size<f64>(&zeros_value), 4);
    try expect_eq_usize(array_size<f64>(&ones_value), 4);
    try expect_eq_usize(array_size<f64>(&scalar_full), 1);
    try expect_eq_usize(scalar_full.storage.len, 1);
    try expect_close_f64(scalar_full.storage.data[0], 3.5, 1e-12);

    var i: usize = 0;
    while i < zeros_value.storage.len {
        try expect_close_f64(zeros_value.storage.data[i], 0.0, 1e-12);
        try expect_close_f64(ones_value.storage.data[i], 1.0, 1e-12);
        i = i + 1;
    }

    if shape_eq(zeros_value.shape, shape2(2, 2)) != true {
        return error.NumuyaExpectationFailed;
    }
    if shape_eq(ones_value.shape, shape2(2, 2)) != true {
        return error.NumuyaExpectationFailed;
    }
    if array_is_c_contiguous<f64>(&zeros_value) != true {
        return error.NumuyaExpectationFailed;
    }
    if array_is_c_contiguous<f64>(&ones_value) != true {
        return error.NumuyaExpectationFailed;
    }

    try expect_eq_usize(array_size<f64>(&full_value), 0);
}

test "creation exports generic from_slice constructor and copies input" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 4] = [1.0, 2.5, 4.0, 8.25];

    const array_value: Array<f64> = try from_slice<f64>(allocator, source[0:4], shape2(2, 2));
    source[0] = 99.0;

    try expect_eq_usize(array_rank<f64>(&array_value), 2);
    try expect_eq_usize(array_size<f64>(&array_value), 4);
    try expect_eq_usize(array_value.storage.len, 4);
    try expect_close_f64(array_value.storage.data[0], 1.0, 1e-12);
    try expect_close_f64(array_value.storage.data[1], 2.5, 1e-12);
    try expect_close_f64(array_value.storage.data[2], 4.0, 1e-12);
    try expect_close_f64(array_value.storage.data[3], 8.25, 1e-12);

    if shape_eq(array_value.shape, shape2(2, 2)) != true {
        return error.NumuyaExpectationFailed;
    }
    if array_is_c_contiguous<f64>(&array_value) != true {
        return error.NumuyaExpectationFailed;
    }
}

test "creation from_slice rejects mismatched slice length" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 3] = [1.0, 2.5, 4.0];

    const result: !Array<f64> = from_slice<f64>(allocator, source[0:3], shape2(2, 2));
    match result {
        error.NumuyaShapeMismatch => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "arange_f64 produces evenly spaced values with positive step" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var arr: Array<f64> = try arange_f64(allocator, 0.0, 5.0, 1.0);
    try expect_eq_usize(array_size<f64>(&arr), 5);
    try expect_close_f64(arr.storage.data[0], 0.0, 1e-12);
    try expect_close_f64(arr.storage.data[1], 1.0, 1e-12);
    try expect_close_f64(arr.storage.data[2], 2.0, 1e-12);
    try expect_close_f64(arr.storage.data[3], 3.0, 1e-12);
    try expect_close_f64(arr.storage.data[4], 4.0, 1e-12);
}

test "arange_f64 with non-unit step" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var arr: Array<f64> = try arange_f64(allocator, 0.0, 10.0, 2.5);
    try expect_eq_usize(array_size<f64>(&arr), 4);
    try expect_close_f64(arr.storage.data[0], 0.0, 1e-12);
    try expect_close_f64(arr.storage.data[1], 2.5, 1e-12);
    try expect_close_f64(arr.storage.data[2], 5.0, 1e-12);
    try expect_close_f64(arr.storage.data[3], 7.5, 1e-12);
}

test "arange_f64 with start != 0" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var arr: Array<f64> = try arange_f64(allocator, 1.5, 4.5, 1.0);
    try expect_eq_usize(array_size<f64>(&arr), 3);
    try expect_close_f64(arr.storage.data[0], 1.5, 1e-12);
    try expect_close_f64(arr.storage.data[1], 2.5, 1e-12);
    try expect_close_f64(arr.storage.data[2], 3.5, 1e-12);
}

test "arange_f64 returns empty when stop <= start with positive step" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var arr: Array<f64> = try arange_f64(allocator, 5.0, 2.0, 1.0);
    try expect_eq_usize(array_size<f64>(&arr), 0);
}

test "arange_f64 rejects zero step" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    const result: !Array<f64> = arange_f64(allocator, 0.0, 5.0, 0.0);
    match result {
        error.NumuyaInvalidStep => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "linspace_f64 produces inclusive evenly spaced values" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var arr: Array<f64> = try linspace_f64(allocator, 0.0, 10.0, 5);
    try expect_eq_usize(array_size<f64>(&arr), 5);
    try expect_close_f64(arr.storage.data[0], 0.0, 1e-12);
    try expect_close_f64(arr.storage.data[1], 2.5, 1e-12);
    try expect_close_f64(arr.storage.data[2], 5.0, 1e-12);
    try expect_close_f64(arr.storage.data[3], 7.5, 1e-12);
    try expect_close_f64(arr.storage.data[4], 10.0, 1e-12);
}

test "linspace_f64 with num=1 returns single start value" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var arr: Array<f64> = try linspace_f64(allocator, 5.0, 10.0, 1);
    try expect_eq_usize(array_size<f64>(&arr), 1);
    try expect_close_f64(arr.storage.data[0], 5.0, 1e-12);
}

test "linspace_f64 with num=0 returns empty array" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var arr: Array<f64> = try linspace_f64(allocator, 0.0, 10.0, 0);
    try expect_eq_usize(array_size<f64>(&arr), 0);
}
