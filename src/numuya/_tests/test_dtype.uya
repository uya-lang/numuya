use array;
use creation;
use shape;
use testing.expect_close_f64;
use testing.expect_eq_usize;
use testing.expect_shape_eq;
use types;

use std.mem.allocator.IAllocator;
use std.mem.allocator.MallocAllocator;

test "dtype test file imports types module" {
}

fn expect_cstr_eq(actual: &const byte, expected: &const byte) !void {
    var i: usize = 0;
    while true {
        const a: byte = actual[i];
        const e: byte = expected[i];
        if a != e {
            return error.NumuyaExpectationFailed;
        }
        if a == 0 {
            return;
        }
        i = i + 1;
    }
}

test "DType helpers report f64 size name endian and kind" {
    const dt: DType = dtype_f64();
    try expect_eq_usize(dtype_size(dt), 8);
    try expect_cstr_eq(dtype_name(dt), "f64");
    match dtype_kind(dt) {
        DTypeKind.Float => {}
        else => { return error.NumuyaExpectationFailed; }
    }
    if dtype_endian(dt) != Endian.Little {
        return error.NumuyaExpectationFailed;
    }
}

test "DType helpers report f32 size name endian and kind" {
    const dt: DType = dtype_f32();
    try expect_eq_usize(dtype_size(dt), 4);
    try expect_cstr_eq(dtype_name(dt), "f32");
    match dtype_kind(dt) {
        DTypeKind.Float => {}
        else => { return error.NumuyaExpectationFailed; }
    }
