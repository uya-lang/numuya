fn expect_eq_f32(actual: f32, expected: f32, tolerance: f32) !void {
    var diff: f32 = actual - expected;
    if diff < 0.0 {
        diff = 0.0 - diff;
    }
    if diff > tolerance {
        return error.NumuyaExpectationFailed;
    }
}

fn expect_eq_i32(actual: i32, expected: i32) !void {
    if actual != expected {
        return error.NumuyaExpectationFailed;
    }
}

test "ArrayAny wraps Array<f64> and preserves shape and data" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 6] = [1.0, 2.5, 4.0, 8.25, 16.0, 32.0];
    var f64_array_value: Array<f64> = try from_slice<f64>(allocator, source[0:6], shape2(2, 3));

    var any_value: ArrayAny = array_any_from_f64(&f64_array_value);

    const any_shape: Shape = array_any_shape(&any_value);
    try expect_shape_eq(any_shape.dims[0:any_shape.rank], shape2(2, 3).dims[0:2]);

    var view: Array<f64> = try array_any_try_as_f64(&any_value);
    try expect_eq_usize(array_size<f64>(&view), 6);
    try expect_close_f64(view.storage.data[0], 1.0, 1e-12);
    try expect_close_f64(view.storage.data[1], 2.5, 1e-12);
    try expect_close_f64(view.storage.data[5], 32.0, 1e-12);
}

test "ArrayAny try_as_f32 on f64 array returns unsupported dtype" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var f32_source: [f64: 4] = [1.0, 1.0, 1.0, 1.0];
    var f32_array_value: Array<f64> = try from_slice<f64>(allocator, f32_source[0:4], shape1(4));

    var any_value: ArrayAny = array_any_from_f64(&f32_array_value);

    const result: !Array<f32> = array_any_try_as_f32(&any_value);
    match result {
        error.NumuyaUnsupportedDType => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

