    const dt: DType = dtype_u8();
    try expect_eq_usize(dtype_size(dt), 1);
    try expect_cstr_eq(dtype_name(dt), "u8");
    match dtype_kind(dt) {
        DTypeKind.Unsigned => {}
        else => { return error.NumuyaExpectationFailed; }
    }
    if dtype_endian(dt) != Endian.Little {
        return error.NumuyaExpectationFailed;
    }
