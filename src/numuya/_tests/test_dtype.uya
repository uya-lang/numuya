test "ArrayAny from f32 roundtrips through try_as_f32" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f32: 4] = [1.0, 2.5, 4.0, 8.25];
    var f32_array_value: Array<f32> = try from_slice<f32>(allocator, source[0:4], shape1(4));

    var any_value: ArrayAny = try array_any_from_f32(&f32_array_value);

    const any_shape: Shape = array_any_shape(&any_value);
    try expect_shape_eq(any_shape.dims[0:any_shape.rank], shape1(4).dims[0:1]);

    var view: Array<f32> = try array_any_try_as_f32(&any_value);
    try expect_eq_usize(array_size<f32>(&view), 4);
    try expect_eq_f32(view.storage.data[0], 1.0, 1e-6);
    try expect_eq_f32(view.storage.data[1], 2.5, 1e-6);
    try expect_eq_f32(view.storage.data[3], 8.25, 1e-6);
}

test "ArrayAny from f32 rejects try_as_f64 as unsupported dtype" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f32: 2] = [1.0, 2.0];
    var f32_array_value: Array<f32> = try from_slice<f32>(allocator, source[0:2], shape1(2));

    var any_value: ArrayAny = try array_any_from_f32(&f32_array_value);

    const result: !Array<f64> = array_any_try_as_f64(&any_value);
    match result {
        error.NumuyaUnsupportedDType => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "ArrayAny from i32 roundtrips through try_as_i32" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [i32: 4] = [1, -2, 7, 42];
    var i32_array_value: Array<i32> = try from_slice<i32>(allocator, source[0:4], shape1(4));

    var any_value: ArrayAny = try array_any_from_i32(&i32_array_value);

    const any_shape: Shape = array_any_shape(&any_value);
    try expect_shape_eq(any_shape.dims[0:any_shape.rank], shape1(4).dims[0:1]);

    var view: Array<i32> = try array_any_try_as_i32(&any_value);
    try expect_eq_usize(array_size<i32>(&view), 4);
    try expect_eq_i32(view.storage.data[0], 1);
    try expect_eq_i32(view.storage.data[1], -2);
    try expect_eq_i32(view.storage.data[3], 42);
}

