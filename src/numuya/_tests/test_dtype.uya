    var i32_source: [f64: 2] = [1.0, 1.0];
    var i32_array_value: Array<f64> = try from_slice<f64>(allocator, i32_source[0:2], shape1(2));

    var any_value: ArrayAny = array_any_from_f64(i32_array_value);

    const result: !&Array<i32> = array_any_try_as_i32(&any_value);
    match result {
        error.NumuyaUnsupportedDType => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}
