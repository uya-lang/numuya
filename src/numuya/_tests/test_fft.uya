test "ifft inverts fft for real input" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 4] = [1.0, 2.0, 3.0, 4.0];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:4], shape1(4));

    var spectrum: ComplexArray = try fft_f64(allocator, &input);
    var recovered: ComplexArray = try ifft(allocator, &spectrum);

    try expect_eq_usize(recovered.values.shape.rank, 1);
    try expect_eq_usize(recovered.values.shape.dims[0], 4);
    try expect_complex_at(&recovered, 0, 1.0, 0.0, 1e-12);
    try expect_complex_at(&recovered, 1, 2.0, 0.0, 1e-12);
    try expect_complex_at(&recovered, 2, 3.0, 0.0, 1e-12);
    try expect_complex_at(&recovered, 3, 4.0, 0.0, 1e-12);
}

test "ifft inverts fft for complex input" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var values: [Complex: 4] = [
        Complex{ re: 1.0, im: 0.5 },
        Complex{ re: 2.0, im: -0.5 },
        Complex{ re: 3.0, im: 1.0 },
        Complex{ re: 4.0, im: -1.0 },
    ];
    var input_values: Array<Complex> = try from_slice<Complex>(allocator, values[0:4], shape1(4));
    var input: ComplexArray = ComplexArray{ values: input_values };

    var spectrum: ComplexArray = try fft(allocator, &input);
    var recovered: ComplexArray = try ifft(allocator, &spectrum);

    try expect_eq_usize(recovered.values.shape.rank, 1);
    try expect_eq_usize(recovered.values.shape.dims[0], 4);
    try expect_complex_at(&recovered, 0, 1.0, 0.5, 1e-12);
    try expect_complex_at(&recovered, 1, 2.0, -0.5, 1e-12);
    try expect_complex_at(&recovered, 2, 3.0, 1.0, 1e-12);
    try expect_complex_at(&recovered, 3, 4.0, -1.0, 1e-12);
}

test "fft_f64 rejects non power of two length" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var data: [f64: 3] = [1.0, 2.0, 3.0];
    var input: Array<f64> = try from_slice<f64>(allocator, data[0:3], shape1(3));

    const result: !ComplexArray = fft_f64(allocator, &input);
    match result {
        error.NumuyaInvalidArgument => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

