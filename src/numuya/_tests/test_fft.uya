test "ifft rejects non power of two length" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var values_ifft: [Complex: 3] = [
        Complex{ re: 1.0, im: 0.0 },
        Complex{ re: 2.0, im: 0.0 },
        Complex{ re: 3.0, im: 0.0 },
    ];
    var input_ifft_values: Array<Complex> = try from_slice<Complex>(allocator, values_ifft[0:3], shape1(3));
    var input_ifft: ComplexArray = ComplexArray{ values: input_ifft_values };

    const result: !ComplexArray = ifft(allocator, &input_ifft);
    match result {
        error.NumuyaInvalidArgument => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}
