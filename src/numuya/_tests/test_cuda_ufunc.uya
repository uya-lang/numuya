    try expect_close_f64(try get2<f64>(&host_result, 0, 0), try get2<f64>(&cpu_result, 0, 0), 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 0, 1), try get2<f64>(&cpu_result, 0, 1), 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 0, 2), try get2<f64>(&cpu_result, 0, 2), 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 1, 0), try get2<f64>(&cpu_result, 1, 0), 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 1, 1), try get2<f64>(&cpu_result, 1, 1), 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 1, 2), try get2<f64>(&cpu_result, 1, 2), 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 0, 0), 5.0, 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 0, 1), 5.0, 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 0, 2), 6.0, 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 1, 0), 20.0, 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 1, 1), 12.5, 1e-12);
    try expect_close_f64(try get2<f64>(&host_result, 1, 2), 12.0, 1e-12);
