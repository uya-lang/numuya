test "gpu_add_f64 output is a new owner independent of inputs" {
    if !backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Cuda);
    defer backend_deinit(&state) catch {};

    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var pool: MemoryPool = memory_pool_new(4 * NUMUYA_MIB);

    var left_data: [f64: 3] = [1.0, 2.0, 3.0];
    var right_data: [f64: 3] = [4.0, 5.0, 6.0];
    var host_left: Array<f64> = try from_slice<f64>(allocator, left_data[0:3], shape1(3));
    var host_right: Array<f64> = try from_slice<f64>(allocator, right_data[0:3], shape1(3));

    var device_left: DeviceArray<f64> = try device_array_from_host<f64>(&pool, &host_left, state.context, state.stream);
    var device_right: DeviceArray<f64> = try device_array_from_host<f64>(&pool, &host_right, state.context, state.stream);

    var device_result: DeviceArray<f64> = try gpu_add_f64(&state, &device_left, &device_right);

    try expect_eq_usize(device_result.storage.ref_count, 1);
    if device_result.flags.owns_data != true {
        return error.NumuyaExpectationFailed;
    }
}
