use array;
use creation;
use indexing;
use shape;
use testing.expect_close_f64;

use std.mem.allocator.IAllocator;
use std.mem.allocator.MallocAllocator;

fn make_array1(allocator: IAllocator, dim0: usize) !Array<f64> {
    const array_value: Array<f64> = try empty<f64>(allocator, shape1(dim0));
    return array_value;
}

fn make_array2(allocator: IAllocator, dim0: usize, dim1: usize) !Array<f64> {
    const array_value: Array<f64> = try empty<f64>(allocator, shape2(dim0, dim1));
    return array_value;
}

fn make_array3(allocator: IAllocator, dim0: usize, dim1: usize, dim2: usize) !Array<f64> {
    const array_value: Array<f64> = try empty<f64>(allocator, shape3(dim0, dim1, dim2));
    return array_value;
}

test "set1 and get1 read back rank-one elements" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var array_value: Array<f64> = try make_array1(allocator, 4);

    const set_first: !void = set1<f64>(&array_value, 0, 1.0);
    const set_last: !void = set1<f64>(&array_value, 3, 4.5);
    try set_first;
    try set_last;

    const first_value: !f64 = get1<f64>(&array_value, 0);
    const last_value: !f64 = get1<f64>(&array_value, 3);
    try expect_close_f64(try first_value, 1.0, 1e-12);
    try expect_close_f64(try last_value, 4.5, 1e-12);
}

test "set2 and getn use row-major physical indexing" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var array_value: Array<f64> = try make_array2(allocator, 2, 3);
    var indices: [usize: 2] = [1, 2];

    const set00: !void = set2<f64>(&array_value, 0, 0, 1.0);
    const set01: !void = set2<f64>(&array_value, 0, 1, 2.5);
    const set10: !void = set2<f64>(&array_value, 1, 0, 4.0);
    const set12: !void = set2<f64>(&array_value, 1, 2, 9.5);
    try set00;
    try set01;
    try set10;
    try set12;

    const value00: !f64 = get2<f64>(&array_value, 0, 0);
    const value01: !f64 = get2<f64>(&array_value, 0, 1);
    const value10: !f64 = get2<f64>(&array_value, 1, 0);
    const value12: !f64 = getn<f64>(&array_value, indices[0:2]);
    try expect_close_f64(try value00, 1.0, 1e-12);
    try expect_close_f64(try value01, 2.5, 1e-12);
    try expect_close_f64(try value10, 4.0, 1e-12);
    try expect_close_f64(try value12, 9.5, 1e-12);
}

test "setn and get3 share contiguous indexing math" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var array_value: Array<f64> = try make_array3(allocator, 2, 2, 2);
    var indices: [usize: 3] = [1, 0, 1];

    const set_value: !void = setn<f64>(&array_value, indices[0:3], 7.25);
    try set_value;

    const value3: !f64 = get3<f64>(&array_value, 1, 0, 1);
    const valuen: !f64 = getn<f64>(&array_value, indices[0:3]);
    try expect_close_f64(try value3, 7.25, 1e-12);
    try expect_close_f64(try valuen, 7.25, 1e-12);
}

test "set helpers reject read-only arrays" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var array1: Array<f64> = try make_array1(allocator, 4);
    var array2: Array<f64> = try make_array2(allocator, 2, 3);
    var array3: Array<f64> = try make_array3(allocator, 2, 2, 2);
    var indices: [usize: 3] = [1, 0, 1];

    array1.flags.writeable = false;
    array2.flags.writeable = false;
    array3.flags.writeable = false;

    const set1_result: !void = set1<f64>(&array1, 0, 1.0);
    match set1_result {
        error.NumuyaReadOnly => {}
        else => { return error.NumuyaExpectationFailed; }
    }

    const set2_result: !void = set2<f64>(&array2, 0, 1, 2.5);
    match set2_result {
        error.NumuyaReadOnly => {}
        else => { return error.NumuyaExpectationFailed; }
    }

    const setn_result: !void = setn<f64>(&array3, indices[0:3], 7.25);
    match setn_result {
        error.NumuyaReadOnly => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "get helpers reject bounds and rank mismatches" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var array_value: Array<f64> = try make_array2(allocator, 2, 3);
    var wrong_rank: [usize: 1] = [0];

    const get1_rank_result: !f64 = get1<f64>(&array_value, 0);
    match get1_rank_result {
        error.NumuyaInvalidArgument => {}
        else => { return error.NumuyaExpectationFailed; }
    }

    const get_result: !f64 = get2<f64>(&array_value, 2, 0);
    match get_result {
        error.NumuyaIndexOutOfBounds => {}
        else => { return error.NumuyaExpectationFailed; }
    }

    const get3_rank_result: !f64 = get3<f64>(&array_value, 0, 0, 0);
    match get3_rank_result {
        error.NumuyaInvalidArgument => {}
        else => { return error.NumuyaExpectationFailed; }
    }

    const getn_result: !f64 = getn<f64>(&array_value, wrong_rank[0:1]);
    match getn_result {
        error.NumuyaInvalidArgument => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "set helpers reject bounds and rank mismatches" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var array_value: Array<f64> = try make_array2(allocator, 2, 3);
    var wrong_rank: [usize: 3] = [0, 0, 0];

    const set_result: !void = set2<f64>(&array_value, 1, 3, 1.0);
    match set_result {
        error.NumuyaIndexOutOfBounds => {}
        else => { return error.NumuyaExpectationFailed; }
    }

    const setn_result: !void = setn<f64>(&array_value, wrong_rank[0:3], 1.0);
    match setn_result {
        error.NumuyaShapeMismatch => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}
