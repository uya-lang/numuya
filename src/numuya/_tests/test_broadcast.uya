use array;
use broadcast;
use creation;
use indexing;
use shape;
use testing.expect_close_f64;
use testing.expect_eq_usize;

use std.mem.allocator.IAllocator;
use std.mem.allocator.MallocAllocator;

test "broadcast_shapes aligns trailing dimensions" {
    const result: Shape = try broadcast_shapes(shape1(3), shape2(2, 3));

    try expect_eq_usize(result.rank, 2);
    try expect_eq_usize(result.dims[0], 2);
    try expect_eq_usize(result.dims[1], 3);
}

test "broadcast_shapes matches size-1 with larger dimension" {
    const result: Shape = try broadcast_shapes(shape3(4, 1, 3), shape3(1, 5, 3));

    try expect_eq_usize(result.rank, 3);
    try expect_eq_usize(result.dims[0], 4);
    try expect_eq_usize(result.dims[1], 5);
    try expect_eq_usize(result.dims[2], 3);
}

test "broadcast_shapes rejects incompatible trailing dimensions" {
    const result: !Shape = broadcast_shapes(shape1(2), shape1(3));
    match result {
        error.NumuyaBroadcastError => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "broadcast_to expands rank with zero stride" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 3] = [1.0, 2.0, 3.0];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:3], shape1(3));

    var broadcasted: Array<f64> = try broadcast_to<f64>(&original, shape2(2, 3));

    try expect_eq_usize(broadcasted.shape.rank, 2);
    try expect_eq_usize(broadcasted.shape.dims[0], 2);
    try expect_eq_usize(broadcasted.shape.dims[1], 3);
    try expect_eq_usize((broadcasted.strides.steps[0] as! usize).value, 0);
    try expect_eq_usize((broadcasted.strides.steps[1] as! usize).value, 1);

    try expect_close_f64(try get2<f64>(&broadcasted, 0, 0), 1.0, 1e-12);
    try expect_close_f64(try get2<f64>(&broadcasted, 0, 1), 2.0, 1e-12);
    try expect_close_f64(try get2<f64>(&broadcasted, 0, 2), 3.0, 1e-12);
    try expect_close_f64(try get2<f64>(&broadcasted, 1, 0), 1.0, 1e-12);
    try expect_close_f64(try get2<f64>(&broadcasted, 1, 1), 2.0, 1e-12);
    try expect_close_f64(try get2<f64>(&broadcasted, 1, 2), 3.0, 1e-12);
}

test "broadcast_to turns leading size-1 into zero stride" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 3] = [1.0, 2.0, 3.0];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:3], shape2(1, 3));

    var broadcasted: Array<f64> = try broadcast_to<f64>(&original, shape2(2, 3));

    try expect_eq_usize(broadcasted.shape.rank, 2);
    try expect_eq_usize(broadcasted.shape.dims[0], 2);
    try expect_eq_usize(broadcasted.shape.dims[1], 3);
    try expect_eq_usize((broadcasted.strides.steps[0] as! usize).value, 0);
    try expect_eq_usize((broadcasted.strides.steps[1] as! usize).value, 1);

    try expect_close_f64(try get2<f64>(&broadcasted, 0, 0), 1.0, 1e-12);
    try expect_close_f64(try get2<f64>(&broadcasted, 1, 2), 3.0, 1e-12);
}

test "broadcast_to rejects incompatible target shape" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 2] = [1.0, 2.0];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:2], shape1(2));

    const result: !Array<f64> = broadcast_to<f64>(&original, shape1(3));
    match result {
        error.NumuyaBroadcastError => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "broadcast view is read-only by default" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 3] = [1.0, 2.0, 3.0];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:3], shape1(3));

    var broadcasted: Array<f64> = try broadcast_to<f64>(&original, shape2(2, 3));

    if broadcasted.flags.writeable != false {
        return error.NumuyaExpectationFailed;
    }

    const result: !void = set2<f64>(&broadcasted, 0, 0, 9.5);
    match result {
        error.NumuyaReadOnly => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}
