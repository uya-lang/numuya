use testing.expect_close_f64;

test "expect_close_f64 accepts values within tolerance" {
    try expect_close_f64(1.0, 1.0 + 1e-13, 1e-12);
}

test "expect_close_f64 rejects values outside tolerance" {
    const result: !void = expect_close_f64(1.0, 1.1, 1e-12);
    match result {
        error.NumuyaExpectationFailed => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}
