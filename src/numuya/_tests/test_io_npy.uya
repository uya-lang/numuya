    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var expected: [u8: 6] = [1, 2, 7, 42, 0, 255];
    var source: Array<u8> = try from_slice<u8>(allocator, expected[0:6], shape2(2, 3));
    errdefer {
        _ = unlink(NPY_ROUNDTRIP_U8_2D);
    }

    try save_npy_u8(NPY_ROUNDTRIP_U8_2D, &source);

    var actual: Array<u8> = try load_npy_u8(allocator, NPY_ROUNDTRIP_U8_2D);
    try expect_array2_eq_u8(&actual, 2, 3, expected[0:6]);

    _ = unlink(NPY_ROUNDTRIP_U8_2D);
}
