test "save_npy_f32 roundtrips 2d array through load_npy_f32" {
    _ = unlink(NPY_ROUNDTRIP_F32_2D);

    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var expected: [f32: 6] = [1.25, -2.5, 3.75, 4.5, 0.0, 9.125];
    var source: Array<f32> = try from_slice<f32>(allocator, expected[0:6], shape2(2, 3));
    errdefer {
        _ = unlink(NPY_ROUNDTRIP_F32_2D);
    }

    try save_npy_f32(NPY_ROUNDTRIP_F32_2D, &source);

    var actual: Array<f32> = try load_npy_f32(allocator, NPY_ROUNDTRIP_F32_2D);
    try expect_array2_eq_f32(&actual, 2, 3, expected[0:6]);

    _ = unlink(NPY_ROUNDTRIP_F32_2D);
}

