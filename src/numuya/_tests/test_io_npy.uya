test "load_npy_f64 rejects unsupported dtype fixture" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;

    const result: !Array<f64> = load_npy_f64(allocator, NPY_FIXTURE_I32_1D);
    match result {
        error.NumuyaUnsupportedDType => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "save_npy_f64 roundtrips 2d array through load_npy_f64" {
    _ = unlink(NPY_ROUNDTRIP_F64_2D);

    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var expected: [f64: 6] = [1.25, -2.5, 3.75, 4.5, 0.0, 9.125];
    var source: Array<f64> = try from_slice<f64>(allocator, expected[0:6], shape2(2, 3));
    errdefer {
        _ = unlink(NPY_ROUNDTRIP_F64_2D);
    }

    try save_npy_f64(NPY_ROUNDTRIP_F64_2D, &source);

    var actual: Array<f64> = try load_npy_f64(allocator, NPY_ROUNDTRIP_F64_2D);
    try expect_array2_close_f64(&actual, 2, 3, expected[0:6]);

    _ = unlink(NPY_ROUNDTRIP_F64_2D);
}

fn expect_eq_f32(actual: f32, expected: f32, tolerance: f32) !void {
    var diff: f32 = actual - expected;
    if diff < 0.0 {
        diff = 0.0 - diff;
    }
    if diff > tolerance {
        return error.NumuyaExpectationFailed;
    }
}

fn expect_array1_eq_f32(actual: &Array<f32>, expected_values: &[f32]) !void {
    try expect_eq_usize(actual.shape.rank, 1);
    try expect_eq_usize(actual.shape.dims[0], expected_values.len);
    try expect_eq_usize(array_size<f32>(actual), expected_values.len);

    var i: usize = 0;
    while i < expected_values.len {
        try expect_eq_f32(try get1<f32>(actual, i), expected_values[i], 1e-6);
        i = i + 1;
    }
}

fn expect_array2_eq_f32(actual: &Array<f32>, dim0: usize, dim1: usize, expected_values: &[f32]) !void {
    var expected_shape: [usize: 2] = [dim0, dim1];
    try expect_shape_eq(actual.shape.dims[0:actual.shape.rank], expected_shape[0:2]);
    try expect_eq_usize(array_size<f32>(actual), expected_values.len);
    try expect_eq_usize(expected_values.len, dim0 * dim1);

    var row: usize = 0;
    while row < dim0 {
        var col: usize = 0;
        while col < dim1 {
            const flat_index: usize = row * dim1 + col;
            try expect_eq_f32(
                try get2<f32>(actual, row, col),
                expected_values[flat_index],
                1e-6,
            );
            col = col + 1;
        }
        row = row + 1;
    }
}

fn expect_empty_array_f32(actual: &Array<f32>, expected_shape: &[usize]) !void {
    try expect_shape_eq(actual.shape.dims[0:actual.shape.rank], expected_shape);
    try expect_eq_usize(array_size<f32>(actual), 0);
}

