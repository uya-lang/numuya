    try expect_close_f64(result.hist.storage.data[1], 1.0, 1e-12);
}

test "histogram_f64 handles non-contiguous transpose view" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 4] = [0.5, 2.5, 1.5, 3.5];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:4], shape2(2, 2));
    var transposed: Array<f64> = try transpose<f64>(&original);

