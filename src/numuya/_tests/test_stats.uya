test "percentile_f64 handles non-contiguous transpose view" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 6] = [6.0, 2.0, 4.0, 1.0, 5.0, 3.0];
    var original: Array<f64> = try from_slice<f64>(allocator, source[0:6], shape2(2, 3));
    var transposed: Array<f64> = try transpose<f64>(&original);

    const result: f64 = try percentile_f64(&transposed, 50.0);

    // sorted [1,2,3,4,5,6], position=0.5*5=2.5, result=3.5
    try expect_close_f64(result, 3.5, 1e-12);
}
