test "corrcoef_f64 perfect positive correlation" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 6] = [0.0, 1.0, 2.0, 0.0, 2.0, 4.0];
    var m: Array<f64> = try from_slice<f64>(allocator, source[0:6], shape2(2, 3));

    var corr: Array<f64> = try corrcoef_f64(&m, null, true);

    try expect_eq_usize(corr.shape.dims[0], 2);
    try expect_eq_usize(corr.shape.dims[1], 2);
    try expect_close_f64(corr.storage.data[0], 1.0, 1e-12);
    try expect_close_f64(corr.storage.data[1], 1.0, 1e-12);
    try expect_close_f64(corr.storage.data[2], 1.0, 1e-12);
    try expect_close_f64(corr.storage.data[3], 1.0, 1e-12);
}

test "corrcoef_f64 perfect negative correlation" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 6] = [0.0, 1.0, 2.0, 2.0, 1.0, 0.0];
    var m: Array<f64> = try from_slice<f64>(allocator, source[0:6], shape2(2, 3));

    var corr: Array<f64> = try corrcoef_f64(&m, null, true);

    try expect_eq_usize(corr.shape.dims[0], 2);
    try expect_eq_usize(corr.shape.dims[1], 2);
    try expect_close_f64(corr.storage.data[0], 1.0, 1e-12);
    try expect_close_f64(corr.storage.data[1], -1.0, 1e-12);
    try expect_close_f64(corr.storage.data[2], -1.0, 1e-12);
    try expect_close_f64(corr.storage.data[3], 1.0, 1e-12);
}

