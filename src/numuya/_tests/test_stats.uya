test "percentile_f64 returns minimum for q=0" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var source: [f64: 5] = [3.0, 1.0, 4.0, 1.0, 5.0];
    var a: Array<f64> = try from_slice<f64>(allocator, source[0:5], shape1(5));

    const result: f64 = try percentile_f64(&a, 0.0);

    try expect_close_f64(result, 1.0, 1e-12);
}

test "percentile_f64 returns median for q=50" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
