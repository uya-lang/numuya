    var host: Array<f64> = try from_slice<f64>(allocator, source[0:6], shape2(2, 3));
    var device: DeviceArray<f64> = try device_array_from_host<f64>(&pool, &host, state.context, state.stream);

    var gpu_result: DeviceArray<usize> = try gpu_argmax_axis_f64(&state, &device, 1, false);
    var host_result: Array<usize> = try device_array_to_host<usize>(allocator, &gpu_result);
    var cpu_result: Array<usize> = try argmax_axis_f64(&host, 1, false);

