    var pool: MemoryPool = memory_pool_new(4 * NUMUYA_MIB);

    var source: [f64: 3] = [1.0, 2.0, 3.0];
    var host: Array<f64> = try from_slice<f64>(allocator, source[0:3], shape1(3));
    var device: DeviceArray<f64> = try device_array_from_host<f64>(&pool, &host, state.context, state.stream);

    const gpu_result: f64 = try gpu_sum_all_f64(&state, &device);
