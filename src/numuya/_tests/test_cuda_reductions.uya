test "gpu_sum_all_f32 large array of ones" {
    if !backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Cuda);
    defer backend_deinit(&state) catch {};

    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var pool: MemoryPool = memory_pool_new(16 * NUMUYA_MIB);

    const n: usize = 10000;
    var host: Array<f32> = try full<f32>(allocator, shape1(n), 1.0);
    var device: DeviceArray<f32> = try device_array_from_host<f32>(&pool, &host, state.context, state.stream);

    const gpu_result: f32 = try gpu_sum_all_f32(&state, &device);

    try expect_close_f64((gpu_result as f64), (n as! f64).value, 1e-3);
}
