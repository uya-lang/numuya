use backend;
use cuda.driver;
use errors;
use testing.expect_eq_usize;

const NUMUYA_GIB: usize = 1024 * 1024 * 1024;

test "backend_is_cuda_available returns true on RTX 3060 without crashing" {
    const available: bool = backend_is_cuda_available();
    // 本机 RTX 3060 期望为 true；实现若仍返回 false 说明尚未真正检测 CUDA。
    // 无 CUDA 环境时函数应不崩溃并返回 false，该属性由本测试调用本身保证。
    if !available {
        return error.NumuyaExpectationFailed;
    }
}

test "cuda_init succeeds when cuda is available and errors gracefully otherwise" {
    const available: bool = backend_is_cuda_available();
    const result: !void = cuda_init();
    if available {
        try result;
    } else {
        // 无 CUDA 时允许返回 NumuyaGpuUnavailable 或 NumuyaCudaError。
        _ = result catch {};
    }
}

test "cuda_get_device(0) reports Ampere sm_86 and more than 8GB on available cuda" {
    if !backend_is_cuda_available() {
        return;
    }
    try cuda_init();

    const device: CudaDevice = try cuda_get_device(0);

    if device.ordinal != 0 {
        return error.NumuyaExpectationFailed;
    }
    if device.major == 0 && device.minor == 0 {
        return error.NumuyaExpectationFailed;
    }
    if device.total_memory_bytes <= 8 * NUMUYA_GIB {
        return error.NumuyaExpectationFailed;
    }
}

test "backend_init with Cpu kind does not require cuda" {
    var state: BackendState = try backend_init(BackendKind.Cpu);
    try backend_deinit(&state);
}

test "backend_init with Cuda kind succeeds when cuda is available" {
    if !backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Cuda);
    try backend_deinit(&state);
}

test "backend_init with Auto kind picks a working backend" {
    var state: BackendState = try backend_init(BackendKind.Auto);
    try backend_deinit(&state);
}

test "backend_init with Cuda kind returns error when cuda is unavailable" {
    if backend_is_cuda_available() {
        return;
    }
    const result: !BackendState = backend_init(BackendKind.Cuda);
    match result {
        error.NumuyaGpuUnavailable => {}
        error.NumuyaCudaError => {}
        else => { return error.NumuyaExpectationFailed; }
    }
}

test "backend_init with Auto kind falls back to Cpu when cuda is unavailable" {
    if backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Auto);
    if state.kind != BackendKind.Cpu {
        return error.NumuyaExpectationFailed;
    }
    try backend_deinit(&state);
}

test "backend_init with Auto kind picks Cuda when cuda is available" {
    if !backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Auto);
    if state.kind != BackendKind.Cuda {
        return error.NumuyaExpectationFailed;
    }
    try backend_deinit(&state);
}

test "backend_deinit returns NumuyaInvalidArgument while device storage is active" {
    var state: BackendState = try backend_init(BackendKind.Cpu);
    backend_device_storage_retain();
    const deinit_result: !void = backend_deinit(&state);
    match deinit_result {
        error.NumuyaInvalidArgument => {}
        else => { return error.NumuyaExpectationFailed; }
    }
    backend_device_storage_release();
    try backend_deinit(&state);
}

test "backend_deinit resets state handles when no active device storage" {
    var state: BackendState = try backend_init(BackendKind.Cpu);
    try backend_deinit(&state);
    if state.kind != BackendKind.Auto {
        return error.NumuyaExpectationFailed;
    }
    if state.context != 0 || state.stream != 0 || state.module != 0 || state.pool != 0 {
        return error.NumuyaExpectationFailed;
    }
}
