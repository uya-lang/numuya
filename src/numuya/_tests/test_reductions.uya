    var result: Array<f64> = try sum_axis_f64(&a, -1, false);

    try expect_eq_usize(result.shape.rank, 1);
    try expect_eq_usize(result.shape.dims[0], 2);
    try expect_close_f64(try get1<f64>(&result, 0), 6.0, 1e-12);
