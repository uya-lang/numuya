use array;
use backend;
use cuda.device_array;
use cuda.memory;
use cuda.random;
use shape;
use testing.expect_eq_usize;

use std.mem.allocator.IAllocator;
use std.mem.allocator.MallocAllocator;

const NUMUYA_MIB: usize = 1024 * 1024;
const F32_TOL: f32 = 1e-4;

fn expect_eq_f32(actual: f32, expected: f32, tolerance: f32) !void {
    var diff: f32 = actual - expected;
    if diff < 0.0 {
        diff = 0.0 - diff;
    }
    if diff > tolerance {
        return error.NumuyaExpectationFailed;
    }
}

test "cuda random test file imports cuda.random module" {
}

test "gpu_random_f32 produces deterministic sequence for fixed seed" {
    if !backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Cuda);
    defer backend_deinit(&state) catch {};

    var pool: MemoryPool = memory_pool_new(4 * NUMUYA_MIB);

    var device_a: DeviceArray<f32> = try gpu_random_f32(&state, &pool, shape2(2, 3), 42);
    var device_b: DeviceArray<f32> = try gpu_random_f32(&state, &pool, shape2(2, 3), 42);

    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var host_a: Array<f32> = try device_array_to_host<f32>(allocator, &device_a);
    var host_b: Array<f32> = try device_array_to_host<f32>(allocator, &device_b);

    try expect_eq_usize(host_a.shape.rank, 2);
    try expect_eq_usize(host_a.shape.dims[0], 2);
    try expect_eq_usize(host_a.shape.dims[1], 3);

    var i: usize = 0;
    while i < 6 {
        try expect_eq_f32(host_a.storage.data[i], host_b.storage.data[i], F32_TOL);
        i = i + 1;
    }
}

test "gpu_random_f32 values are in half open interval zero one" {
    if !backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Cuda);
    defer backend_deinit(&state) catch {};

    var pool: MemoryPool = memory_pool_new(4 * NUMUYA_MIB);
    var device: DeviceArray<f32> = try gpu_random_f32(&state, &pool, shape2(10, 10), 12345);

    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var host: Array<f32> = try device_array_to_host<f32>(allocator, &device);

    try expect_eq_usize(host.shape.rank, 2);
    try expect_eq_usize(host.shape.dims[0], 10);
    try expect_eq_usize(host.shape.dims[1], 10);

    var i: usize = 0;
    while i < 100 {
        const value: f32 = host.storage.data[i];
        if value < 0.0 {
            return error.NumuyaExpectationFailed;
        }
        if value >= 1.0 {
            return error.NumuyaExpectationFailed;
        }
        i = i + 1;
    }
}

test "gpu_random_f32 produces different sequences for different seeds" {
    if !backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Cuda);
    defer backend_deinit(&state) catch {};

    var pool: MemoryPool = memory_pool_new(4 * NUMUYA_MIB);
    var device_a: DeviceArray<f32> = try gpu_random_f32(&state, &pool, shape2(4, 4), 1);
    var device_b: DeviceArray<f32> = try gpu_random_f32(&state, &pool, shape2(4, 4), 2);

    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var host_a: Array<f32> = try device_array_to_host<f32>(allocator, &device_a);
    var host_b: Array<f32> = try device_array_to_host<f32>(allocator, &device_b);

    var all_equal: bool = true;
    var i: usize = 0;
    while i < 16 {
        var diff: f32 = host_a.storage.data[i] - host_b.storage.data[i];
        if diff < 0.0 {
            diff = 0.0 - diff;
        }
        if diff > F32_TOL {
            all_equal = false;
        }
        i = i + 1;
    }
    if all_equal {
        return error.NumuyaExpectationFailed;
    }
}

test "gpu_random_f32 output is a new owner independent of pool inputs" {
    if !backend_is_cuda_available() {
        return;
    }
    var state: BackendState = try backend_init(BackendKind.Cuda);
    defer backend_deinit(&state) catch {};

    var pool: MemoryPool = memory_pool_new(4 * NUMUYA_MIB);
    var device: DeviceArray<f32> = try gpu_random_f32(&state, &pool, shape2(2, 2), 99);

    try expect_eq_usize(device.storage.ref_count, 1);
    if device.flags.owns_data != true {
        return error.NumuyaExpectationFailed;
    }
}
