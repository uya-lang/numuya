test "qr_f64 decomposes square matrix into q and r" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var a_data: [f64: 9] = [12.0, -51.0, 4.0, 6.0, 167.0, -68.0, -4.0, 24.0, -41.0];
    var a: Array<f64> = try from_slice<f64>(allocator, a_data[0:9], shape2(3, 3));

    var result: QRResult = try qr_f64(&a);
    var q: Array<f64> = result.q;
    var r: Array<f64> = result.r;

    try expect_eq_usize(q.shape.rank, 2);
    try expect_eq_usize(q.shape.dims[0], 3);
    try expect_eq_usize(q.shape.dims[1], 3);
    try expect_eq_usize(r.shape.rank, 2);
    try expect_eq_usize(r.shape.dims[0], 3);
    try expect_eq_usize(r.shape.dims[1], 3);

    try expect_close_f64(try get2<f64>(&q, 0, 0), 6.0 / 7.0, 1e-12);
    try expect_close_f64(try get2<f64>(&q, 1, 0), 3.0 / 7.0, 1e-12);
    try expect_close_f64(try get2<f64>(&q, 2, 0), -2.0 / 7.0, 1e-12);
    try expect_close_f64(try get2<f64>(&q, 0, 1), -69.0 / 175.0, 1e-12);
    try expect_close_f64(try get2<f64>(&q, 1, 1), 158.0 / 175.0, 1e-12);
    try expect_close_f64(try get2<f64>(&q, 2, 1), 6.0 / 35.0, 1e-12);
    try expect_close_f64(try get2<f64>(&q, 0, 2), -58.0 / 175.0, 1e-12);
    try expect_close_f64(try get2<f64>(&q, 1, 2), 6.0 / 175.0, 1e-12);
    try expect_close_f64(try get2<f64>(&q, 2, 2), -33.0 / 35.0, 1e-12);

    try expect_close_f64(try get2<f64>(&r, 0, 0), 14.0, 1e-12);
    try expect_close_f64(try get2<f64>(&r, 0, 1), 21.0, 1e-12);
    try expect_close_f64(try get2<f64>(&r, 0, 2), -14.0, 1e-12);
    try expect_close_f64(try get2<f64>(&r, 1, 1), 175.0, 1e-12);
    try expect_close_f64(try get2<f64>(&r, 1, 2), -70.0, 1e-12);
    try expect_close_f64(try get2<f64>(&r, 2, 2), 35.0, 1e-12);
    try expect_close_f64(try get2<f64>(&r, 1, 0), 0.0, 1e-12);
    try expect_close_f64(try get2<f64>(&r, 2, 0), 0.0, 1e-12);
    try expect_close_f64(try get2<f64>(&r, 2, 1), 0.0, 1e-12);
}
