use array;
use creation;
use indexing;
use linalg;
use shape;
use stride;
use storage;
use testing.expect_close_f64;
use testing.expect_eq_usize;

use std.mem.allocator.IAllocator;
use std.mem.allocator.MallocAllocator;

test "linalg test file imports linalg module" {
}

test "eye_f64 creates identity matrix with k=0" {
    var malloc_allocator: MallocAllocator = MallocAllocator{};
    var allocator: IAllocator = malloc_allocator;
    var result: Array<f64> = try eye_f64(allocator, 3, 3, 0);

    try expect_eq_usize(result.shape.rank, 2);
    try expect_eq_usize(result.shape.dims[0], 3);
    try expect_eq_usize(result.shape.dims[1], 3);

    var i: usize = 0;
    while i < 3 {
        var j: usize = 0;
        while j < 3 {
            const expected: f64 = if i == j { 1.0 } else { 0.0 };
            try expect_close_f64(try get2<f64>(&result, i, j), expected, 1e-12);
            j = j + 1;
        }
        i = i + 1;
    }
}

