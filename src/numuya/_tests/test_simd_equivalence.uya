    var left: Array<f64> = try from_slice<f64>(allocator, left_data[0:7], shape1(7));
    var right: Array<f64> = try from_slice<f64>(allocator, right_data[0:7], shape1(7));

    var scalar_result: Array<f64> = try add_f64_scalar(&left, &right);
